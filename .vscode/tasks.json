{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-debug",
            "type": "shell",
            "command": "dotnet build '${workspaceFolder}\\NumDesTools\\NumDesTools.csproj' -c Debug",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build-release",
            "type": "shell",
            "command": "dotnet build '${workspaceFolder}\\NumDesTools\\NumDesTools.csproj' -c Release",
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "copy-xll-debug",
            "type": "shell",
            "command": "& '${workspaceFolder}\\packFromBin\\ReNamePack.bat'",
            "dependsOn": ["build-debug"],
            "problemMatcher": []
        },
        {
            "label": "copy-xll-release",
            "type": "shell",
            "command": "& '${workspaceFolder}\\packFromBin\\ReNamePack.bat'",
            "dependsOn": ["build-release"],
            "problemMatcher": []
        }
    ]
}
