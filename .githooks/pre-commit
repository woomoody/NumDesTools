#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel)
hook_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

if command -v pwsh.exe >/dev/null 2>&1; then
    exec pwsh.exe -NoProfile -ExecutionPolicy Bypass -File "$hook_dir/pre-commit.ps1" -RepoRoot "$repo_root"
fi

if command -v powershell.exe >/dev/null 2>&1; then
    exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$hook_dir/pre-commit.ps1" -RepoRoot "$repo_root"
fi

echo "pre-commit: neither pwsh.exe nor powershell.exe was found." >&2
exit 1
