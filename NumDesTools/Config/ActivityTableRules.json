{
  "_comment": [
    "活动配置验证规则映射。由 AI 分析 Code 业务代码后生成，供 ActivityConfigTester.cs 使用。",
    "人工可直接编辑扩展，无需修改 C# 代码。",
    "",
    "── 验证逻辑说明 ──",
    "  1. 静态规则校验：tables[].fields 的 required / type / refTable 检查（全量）",
    "  2. 配置链追踪（指定ID）：",
    "     ① ActivityClientData[id] 必须存在（组活动也必须有，因为活动组有的活动表必然有）",
    "     ② 若 ActivityClientHierarchyGroupData[id] 存在，则追踪层级链：",
    "        hierarchyActivityIDs[] → ActivityClientHierarchyData[v].activityIds → ActivityClientData",
    "     ③ 根据 ActivityClientData[id].type 查 typeSubTableRules（优先）或 typeTableMap",
    "     ④ type=2(LteActivity)：LteData[activityID] → mapData/mapIdList → MapDataProto → prefab 文件存在"
  ],

  "tables": [
    {
      "name": "ActivityClientData",
      "luaKey": "Tables.ActivityClientData",
      "excelFile": "ActivityClientData.xlsx",
      "desc": "客户端活动主表，每条记录对应一个具体活动实例",
      "keyField": "id",
      "fields": [
        { "name": "id",              "desc": "活动唯一ID",                         "required": true,  "type": "number" },
        { "name": "type",            "desc": "活动类型枚举(EnumCmds.ActivityType)", "required": true,  "type": "number" },
        { "name": "activityID",      "desc": "活动数据ID，各LogicBase通过此字段查子表", "required": true, "type": "number" },
        { "name": "isActivityGroup", "desc": "是否活动组",                         "required": false, "type": "number" },
        { "name": "mutexWeight",     "desc": "互斥权重",                           "required": false, "type": "number" },
        { "name": "conditions",      "desc": "开启条件数组",                       "required": false, "type": "table"  },
        { "name": "stopTime",        "desc": "停止开启时间(秒)",                   "required": false, "type": "number" },
        { "name": "childActivity",   "desc": "子活动ID列表",                       "required": false, "type": "table"  },
        { "name": "mainActivityID",  "desc": "主活动ID，引用 ActivityClientData",  "required": false, "type": "number",
          "refTable": "Tables.ActivityClientData" },
        { "name": "minVersion",      "desc": "活动最低版本号",                     "required": false, "type": "string" },
        { "name": "bundleGroupsKey", "desc": "依赖资源组key列表",                  "required": false, "type": "table"  }
      ]
    },
    {
      "name": "ActivityClientHierarchyData",
      "luaKey": "Tables.ActivityClientHierarchyData",
      "excelFile": "ActivityClientHierarchyData.xlsx",
      "desc": "活动等级子表，activityIds 引用主表活动 ID",
      "keyField": "id",
      "fields": [
        { "name": "id",              "desc": "子级唯一ID",                         "required": true,  "type": "number" },
        { "name": "activityIds",     "desc": "引用 ActivityClientData 的活动 ID",  "required": true,  "type": "number",
          "refTable": "Tables.ActivityClientData", "refIsArray": false },
        { "name": "openConditions",  "desc": "开启条件数组",                       "required": false, "type": "table"  },
        { "name": "closeConditions", "desc": "关闭条件数组",                       "required": false, "type": "table"  }
      ]
    },
    {
      "name": "ActivityClientHierarchyGroupData",
      "luaKey": "Tables.ActivityClientHierarchyGroupData",
      "excelFile": "ActivityClientHierarchyGroupData.xlsx",
      "desc": "活动组顶层表，hierarchyActivityIDs 列出组内各等级 ID",
      "keyField": "id",
      "fields": [
        { "name": "id",                   "desc": "活动组唯一ID", "required": true, "type": "number" },
        { "name": "hierarchyActivityIDs", "desc": "数组，引用 ActivityClientHierarchyData 的 id 列表",
          "required": true, "type": "table",
          "refTable": "Tables.ActivityClientHierarchyData", "refIsArray": true }
      ]
    },
    {
      "name": "ActivityServerData",
      "luaKey": "Tables.ActivityServerData",
      "excelFile": "ActivityServerData.xlsx",
      "desc": "服务端活动配置，id 必须在 ActivityClientData 中存在",
      "keyField": "id",
      "fields": [
        { "name": "id", "desc": "活动ID，必须与 ActivityClientData.id 对应",
          "required": true, "type": "number",
          "refTable": "Tables.ActivityClientData", "refIsArray": false }
      ]
    }
  ],

