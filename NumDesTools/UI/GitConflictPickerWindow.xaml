<mah:MetroWindow
    x:Class="NumDesTools.UI.GitConflictPickerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    Title="Git 冲突解决"
    MinWidth="420" MinHeight="260"
    SizeToContent="Height"
    MaxHeight="600"
    WindowStartupLocation="CenterScreen"
    KeyDown="Window_KeyDown">

    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 冲突文件列表 -->
        <ListBox x:Name="FileList"
                 Grid.Row="0"
                 MinHeight="80"
                 FontFamily="Consolas" FontSize="11"
                 BorderThickness="0"
                 Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                 Foreground="{DynamicResource MahApps.Brushes.Text}"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 SelectionMode="Single"
                 MouseDoubleClick="FileList_MouseDoubleClick"
                 KeyDown="FileList_KeyDown">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="8,3"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- 底部操作区 -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray7}"
                BorderThickness="0,1,0,0"
                Padding="10,8">
            <StackPanel>
                <CheckBox x:Name="SkipHashBox"
                          Content="跳过 # 文件（以对方为准自动解决）"
                          Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                          FontSize="11"
                          Margin="0,0,0,8"
                          Checked="SkipHash_Changed"
                          Unchecked="SkipHash_Changed"/>
                <Button x:Name="ResolveBtn"
                        Content="解决选中文件"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                        HorizontalAlignment="Stretch"
                        Padding="0,8"
                        Click="Resolve_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</mah:MetroWindow>
