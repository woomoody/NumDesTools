<mah:MetroWindow
    x:Class="NumDesTools.UI.BranchMergeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    Title="分支合并 / Cherry-pick"
    Width="580" SizeToContent="Height"
    MinHeight="320" MaxHeight="700"
    WindowStartupLocation="CenterScreen"
    KeyDown="Window_KeyDown">

    <Grid Margin="14,12,14,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 模式切换 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton x:Name="MergeRadio" Content="Merge 分支" IsChecked="True"
                         Margin="0,0,20,0" Checked="Mode_Changed"
                         Foreground="{DynamicResource MahApps.Brushes.Text}"/>
            <RadioButton x:Name="CherryRadio" Content="Cherry-pick Commits"
                         Checked="Mode_Changed"
                         Foreground="{DynamicResource MahApps.Brushes.Text}"/>
        </StackPanel>

        <!-- 目标分支 -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="目标分支 (OURS)" VerticalAlignment="Center"
                       Foreground="{DynamicResource MahApps.Brushes.Gray3}" FontSize="11"/>
            <ComboBox x:Name="TargetBranchBox" Grid.Column="1"
                      FontFamily="Consolas" FontSize="11"
                      SelectionChanged="TargetBranch_Changed"/>
        </Grid>

        <!-- Merge 模式：来源分支 -->
        <Grid x:Name="MergeSourceRow" Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="来源分支 (THEIRS)" VerticalAlignment="Center"
                       Foreground="{DynamicResource MahApps.Brushes.Gray3}" FontSize="11"/>
            <ComboBox x:Name="SourceBranchBox" Grid.Column="1"
                      FontFamily="Consolas" FontSize="11"/>
        </Grid>

        <!-- Cherry-pick 模式：commit 列表 -->
        <Grid x:Name="CherryCommitRow" Grid.Row="3" Visibility="Collapsed" Margin="0,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="选择要摘取的 Commits（可多选）："
                       Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                       FontSize="11" Margin="0,0,0,4"/>
            <ListBox x:Name="CommitList" Grid.Row="1"
                     MinHeight="160" MaxHeight="320"
                     FontFamily="Consolas" FontSize="11"
                     BorderThickness="1"
                     BorderBrush="{DynamicResource MahApps.Brushes.Gray7}"
                     Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                     Foreground="{DynamicResource MahApps.Brushes.Text}"
                     SelectionMode="Extended"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="6,2"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Display}" FontFamily="Consolas" FontSize="11"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- 底部按钮 -->
        <Border Grid.Row="4"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray7}"
                BorderThickness="0,1,0,0"
                Padding="0,8" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                           FontSize="11" TextWrapping="Wrap"/>
                <Button x:Name="OkButton" Grid.Column="1" Content="开始合并"
                        Width="88" Height="28" IsDefault="True"
                        Click="Ok_Click"/>
                <Button Grid.Column="3" Content="取消"
                        Width="64" Height="28" IsCancel="True"
                        Click="Cancel_Click"/>
            </Grid>
        </Border>
    </Grid>
</mah:MetroWindow>
