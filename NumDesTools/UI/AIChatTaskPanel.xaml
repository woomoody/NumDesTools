<UserControl
    x:Class="NumDesTools.UI.AiChatTaskPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="870"
    Height="500"
    mc:Ignorable="d">
    <Grid Margin="0" Background="#1c1c1c">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  顶部工具栏：模型选择 + 加载更多 + 清空  -->
        <Grid Grid.Row="0" Margin="4,4,4,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox
                x:Name="ModelComboBox"
                Grid.Column="0"
                Height="26"
                Margin="0,0,6,0"
                Background="#2d2d30"
                Foreground="#e0e0e0"
                BorderBrush="#555"
                SelectionChanged="ModelComboBox_SelectionChanged">
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#2d2d30" />
                        <Setter Property="Foreground" Value="#e0e0e0" />
                        <Setter Property="Padding" Value="8,4" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#094771" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#094771" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.ItemContainerStyle>
                <ComboBox.Template>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                Foreground="{TemplateBinding Foreground}"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                Padding="8,0,4,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="20" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter
                                        Grid.Column="0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="#aaa"
                                        Text="▾" />
                                </Grid>
                            </ToggleButton>
                            <Popup
                                AllowsTransparency="True"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom"
                                PopupAnimation="Slide">
                                <Border
                                    MaxHeight="320"
                                    Background="#2d2d30"
                                    BorderBrush="#555"
                                    BorderThickness="1">
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </ComboBox.Template>
            </ComboBox>
            <Button
                x:Name="ClearAllButton"
                Grid.Column="1"
                Width="68"
                Height="26"
                Margin="0,0,6,0"
                Background="#5a2727"
                Foreground="White"
                Click="ClearAllButton_Click"
                Content="清空全部" />
            <Button
                x:Name="CompressButton"
                Grid.Column="2"
                Width="72"
                Height="26"
                Click="CompressButton_Click"
                Content="压缩上下文" />
        </Grid>

        <!--  会话选择栏  -->
        <Grid Grid.Row="1" Margin="4,0,4,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox
                x:Name="SessionComboBox"
                Grid.Column="0"
                Height="26"
                Margin="0,0,6,0"
                Background="#2d2d30"
                Foreground="#e0e0e0"
                BorderBrush="#555"
                SelectionChanged="SessionComboBox_SelectionChanged">
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#2d2d30" />
                        <Setter Property="Foreground" Value="#e0e0e0" />
                        <Setter Property="Padding" Value="6,3" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#094771" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#094771" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.ItemContainerStyle>
                <ComboBox.Template>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                Foreground="{TemplateBinding Foreground}"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                Padding="8,0,4,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="20" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter
                                        Grid.Column="0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding SelectionBoxItem}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="#aaa"
                                        Text="▾" />
                                </Grid>
                            </ToggleButton>
                            <Popup
                                AllowsTransparency="True"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom"
                                PopupAnimation="Slide">
                                <Border
                                    MaxHeight="300"
                                    Background="#2d2d30"
                                    BorderBrush="#555"
                                    BorderThickness="1">
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </ComboBox.Template>
            </ComboBox>
            <Button
                x:Name="RenameSessionButton"
                Grid.Column="1"
                Width="28"
                Height="26"
                Margin="0,0,4,0"
                Background="#3e3e42"
                Foreground="#ccc"
                Content="✏"
                ToolTip="重命名会话"
                Click="RenameSessionButton_Click" />
            <Button
                x:Name="DeleteSessionButton"
                Grid.Column="2"
                Width="46"
                Height="26"
                Margin="0,0,4,0"
                Background="#5a2727"
                Foreground="White"
                Content="删除"
                Click="DeleteSessionButton_Click" />
            <Button
                x:Name="ImportButton"
                Grid.Column="3"
                Width="46"
                Height="26"
                Margin="0,0,4,0"
                Background="#3e3e42"
                Foreground="#ccc"
                Content="导入"
                Click="ImportButton_Click" />
            <Button
                x:Name="NewChatButton"
                Grid.Column="4"
                Width="70"
                Height="26"
                Background="#2d5a27"
                Foreground="White"
                Content="＋ 新对话"
                Click="NewChatButton_Click" />
        </Grid>

        <!--  输出框  -->
        <WebBrowser
            x:Name="ResponseOutput"
            Grid.Row="2"
            Margin="0,0,0,0" />

        <!--  附件 Strip  -->
        <WrapPanel
            x:Name="AttachmentStrip"
            Grid.Row="3"
            Margin="4,0,4,2"
            Visibility="Collapsed" />

        <!--  输入框和发送按钮  -->
        <Grid Grid.Row="4" Margin="4,2,4,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border
                Grid.Column="0"
                Margin="0,0,6,0"
                BorderBrush="Gray"
                BorderThickness="1">
                <avalonEdit:TextEditor
                    x:Name="PromptInput"
                    MinHeight="36"
                    MaxHeight="200"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    AllowDrop="True"
                    Background="#1c1c1c"
                    Drop="OnInputDrop"
                    FontSize="10pt"
                    Foreground="Gray"
                    GotFocus="PromptInput_GotFocus"
                    HorizontalScrollBarVisibility="Disabled"
                    LostFocus="PromptInput_LostFocus"
                    PreviewKeyDown="PromptInput_PreviewKeyDown"
                    ShowLineNumbers="False"
                    VerticalScrollBarVisibility="Hidden" />
            </Border>
            <Button
                x:Name="AttachButton"
                Grid.Column="1"
                Width="30"
                Margin="0,0,4,0"
                Background="#3e3e42"
                Click="AttachButton_Click"
                Content="📎"
                Foreground="#aaa" />
            <Button
                x:Name="SendButton"
                Grid.Column="2"
                Width="64"
                Background="#0078d4"
                Click="SendButton_Click"
                Content="发送"
                Foreground="White" />
        </Grid>
    </Grid>
</UserControl>
