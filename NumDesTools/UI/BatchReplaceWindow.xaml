<ui:FluentWindow
    x:Class="NumDesTools.UI.BatchReplaceWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="批量替换 (Ctrl+Alt+H)"
    Width="560" Height="460"
    MinWidth="440" MinHeight="340"
    WindowStartupLocation="CenterScreen"
    ShowInTaskbar="True"
    KeyDown="Window_KeyDown"
    Closing="Window_Closing">

    <DockPanel Margin="10">

        <!-- 底部按钮栏 -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <CheckBox x:Name="TopmostCheck" Content="窗口置顶"
                      VerticalAlignment="Center" Margin="0,0,16,0"
                      Checked="TopmostCheck_Changed" Unchecked="TopmostCheck_Changed"/>
            <Button x:Name="ExecuteBtn" Content="执行替换(Ctrl+Enter)"
                    Width="140" Margin="0,0,8,0" IsDefault="False"
                    Click="Execute_Click"/>
            <Button Content="清空" Width="60" Click="Clear_Click"/>
        </StackPanel>

        <!-- 状态条 -->
        <TextBlock x:Name="StatusText" DockPanel.Dock="Bottom"
                   Foreground="Green" FontSize="11" Margin="0,4,0,0"/>

        <!-- 主体：左=规则列表  右=历史 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="160" MinWidth="120"/>
            </Grid.ColumnDefinitions>

            <!-- ══ 左侧：逐行规则 ══ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 列头 -->
                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="28"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="查找值" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="替换值" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                </Grid>

                <!-- 规则列表 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="RuleRows">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding From, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas" Padding="3,2"/>
                                    <TextBlock Grid.Column="1" Text="→" VerticalAlignment="Center"
                                               HorizontalAlignment="Center" Foreground="Gray"/>
                                    <TextBox Grid.Column="2" Text="{Binding To, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas" Padding="3,2"/>
                                    <Button Grid.Column="3" Content="✕" FontSize="10" Margin="2,0,0,0"
                                            Tag="{Binding}"
                                            Click="RemoveRow_Click"
                                            ToolTip="删除此行"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 添加行 -->
                <Button Grid.Row="2" Content="+ 添加一行" HorizontalAlignment="Left"
                        Margin="0,6,0,0" Padding="8,3"
                        Click="AddRow_Click"/>
            </Grid>

            <!-- 分隔条 -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="Transparent" ShowsPreview="False"/>

            <!-- ══ 右侧：历史记录 ══ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="历史记录" FontSize="11" Foreground="Gray" Margin="0,0,0,4"/>

                <ListBox x:Name="HistoryList" Grid.Row="1"
                         BorderThickness="1"
                         SelectionChanged="HistoryList_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}" TextTrimming="CharacterEllipsis"
                                       FontSize="11" ToolTip="{Binding Detail}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Grid.Row="2" Content="清空历史" Margin="0,4,0,0"
                        HorizontalAlignment="Stretch" Padding="4,3"
                        Click="ClearHistory_Click"/>
            </Grid>
        </Grid>
    </DockPanel>
</ui:FluentWindow>
