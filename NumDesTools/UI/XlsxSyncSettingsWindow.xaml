<mah:MetroWindow
    x:Class="NumDesTools.UI.XlsxSyncSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    Title="跨表同步设置"
    Width="620" Height="300" MinWidth="520" MinHeight="260"
    WindowStartupLocation="CenterScreen"
    KeyDown="Window_KeyDown">

    <Grid Margin="14,12,14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="70"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="根目录 A" VerticalAlignment="Center"
                   Foreground="{DynamicResource MahApps.Brushes.Gray3}"/>
        <TextBox x:Name="RootABox" Grid.Row="0" Grid.Column="1" Margin="0,4,6,4"/>
        <Button Grid.Row="0" Grid.Column="2" Content="浏览…" Margin="0,4,0,4" Click="BrowseRootA_Click"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="根目录 B" VerticalAlignment="Center"
                   Foreground="{DynamicResource MahApps.Brushes.Gray3}"/>
        <TextBox x:Name="RootBBox" Grid.Row="1" Grid.Column="1" Margin="0,4,6,4"/>
        <Button Grid.Row="1" Grid.Column="2" Content="浏览…" Margin="0,4,0,4" Click="BrowseRootB_Click"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="a 侧后缀" VerticalAlignment="Center"
                   Foreground="{DynamicResource MahApps.Brushes.Gray3}"/>
        <TextBox x:Name="SuffixABox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,4,0,4"
                 Tag="留空则要求 a/b 文件名完全一致，比如填 _Update 表示 a 侧文件名 = b 侧文件名 + _Update"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,10,0,0"
                   TextWrapping="Wrap" VerticalAlignment="Top"
                   Foreground="{DynamicResource MahApps.Brushes.Gray3}" FontSize="11"
                   Text="同步时按当前打开文件在哪侧根目录下，自动推出对侧文件（按上面的后缀规则换算文件名）；逐个同名 Sheet 比较表头（约定 id 列为 Key），交集列自动同步，不用再配 Sheet 名和列名单。"/>

        <Button x:Name="SaveButton" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                Content="保存" Height="34" IsDefault="True"
                Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                Click="SaveRoots_Click"/>
    </Grid>
</mah:MetroWindow>
