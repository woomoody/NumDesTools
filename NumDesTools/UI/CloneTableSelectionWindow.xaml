<Window
    x:Class="NumDesTools.UI.CloneTableSelectionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="选择克隆目标表"
    Width="520" Height="480" MinWidth="380" MinHeight="300"
    WindowStartupLocation="CenterScreen"
    Background="#1E1E1E"
    FontFamily="微软雅黑">

    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Padding"         Value="16,6"/>
            <Setter Property="Background"      Value="#1A5C3A"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="13"/>
        </Style>
        <Style TargetType="Button" x:Key="SecBtn">
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Background"      Value="#333"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>
        <Style TargetType="Button" x:Key="SmallBtn">
            <Setter Property="Padding"         Value="6,2"/>
            <Setter Property="Background"      Value="#2A2A2A"/>
            <Setter Property="Foreground"      Value="#AAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="11"/>
        </Style>
        <Style TargetType="CheckBox" x:Key="TableCheck">
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="#CCC"/>
            <Setter Property="Margin"     Value="0,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题说明 -->
        <TextBlock Grid.Row="0" Foreground="#AAA" FontSize="12" TextWrapping="Wrap"
                   Margin="0,0,0,8"
                   Text="以下是本次克隆将写入的目标表，取消勾选可跳过对应表。"/>

        <!-- 全选/取消 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="全选" Style="{StaticResource SmallBtn}"
                    Click="SelectAll_Click" Margin="0,0,6,0"/>
            <Button Content="取消全选" Style="{StaticResource SmallBtn}"
                    Click="DeselectAll_Click" Margin="0,0,6,0"/>
            <Button Content="反选" Style="{StaticResource SmallBtn}"
                    Click="Invert_Click"/>
        </StackPanel>

        <!-- 表格复选框列表 -->
        <Border Grid.Row="2" BorderBrush="#333" BorderThickness="1" Background="#252525">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="TableList" Margin="8,6">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding TableName}"
                                      IsChecked="{Binding Selected, Mode=TwoWay}"
                                      Style="{StaticResource TableCheck}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- 底部按钮 -->
        <Border Grid.Row="3" BorderBrush="#333" BorderThickness="0,1,0,0"
                Margin="0,10,0,0" Padding="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Column="0" Foreground="#666"
                           FontSize="11" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="取消" Style="{StaticResource SecBtn}"
                            Margin="0,0,8,0" Click="Cancel_Click"/>
                    <Button Content="▶ 确认并克隆" Style="{StaticResource PrimaryBtn}"
                            Click="Confirm_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
