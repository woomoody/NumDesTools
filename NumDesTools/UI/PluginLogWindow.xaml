<mah:MetroWindow
    x:Class="NumDesTools.UI.PluginLogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    Title="插件日志"
    Width="960"
    Height="600"
    MinWidth="600"
    MinHeight="300"
    WindowStartupLocation="CenterScreen"
    Closing="Window_Closing"
    KeyDown="Window_KeyDown">

    <mah:MetroWindow.Resources>
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Background" Value="#3A3A3A" />
            <Setter Property="Foreground" Value="#F0F0F0" />
            <Setter Property="BorderBrush" Value="#555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#555" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Background="#1A1A1A">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 日志列表 -->
        <ListBox
            x:Name="LogList"
            Grid.Row="0"
            Background="#1A1A1A"
            BorderThickness="0"
            FontFamily="Consolas"
            FontSize="12"
            Foreground="#E8E8E8"
            KeyDown="LogList_KeyDown"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            SelectionMode="Extended"
            VirtualizingPanel.IsVirtualizing="True"
            VirtualizingPanel.VirtualizationMode="Recycling">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="#E8E8E8" />
                    <Setter Property="FontFamily" Value="Consolas" />
                    <Setter Property="Padding" Value="6,2" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#2A5A9A" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2A2A2A" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- 过滤栏 -->
        <Border
            Grid.Row="1"
            Padding="8,5,8,0"
            Background="#252525"
            BorderBrush="#444"
            BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock
                    VerticalAlignment="Center"
                    Margin="0,0,6,0"
                    Foreground="#888"
                    FontSize="11"
                    Text="过滤：" />
                <TextBox
                    x:Name="FilterBox"
                    FontFamily="Consolas"
                    FontSize="12"
                    Background="#1A1A1A"
                    Foreground="#E8E8E8"
                    BorderBrush="#555"
                    Padding="6,3"
                    TextChanged="FilterBox_TextChanged"
                    PreviewMouseDown="FilterBox_PreviewMouseDown"
                    mah:TextBoxHelper.Watermark="输入关键词过滤（支持多词空格分隔）" />
            </DockPanel>
        </Border>

        <!-- 操作栏 -->
        <Border
            Grid.Row="2"
            Padding="8,6"
            Background="#252525">
            <DockPanel>
                <TextBlock
                    x:Name="StatusText"
                    Margin="4,0,12,0"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="#AAAAAA"
                    Text="0 行" />
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button
                        x:Name="BtnAutoScroll"
                        Background="#1A6B3A"
                        Foreground="White"
                        Click="BtnAutoScroll_Click"
                        Content="自动滚动: 开"
                        Style="{StaticResource ToolBtn}" />
                    <Button
                        x:Name="BtnCopy"
                        Click="BtnCopy_Click"
                        Content="复制选中 (Ctrl+C)"
                        Style="{StaticResource ToolBtn}" />
                    <Button
                        x:Name="BtnCopyAll"
                        Click="BtnCopyAll_Click"
                        Content="复制全部"
                        Style="{StaticResource ToolBtn}" />
                    <Button
                        x:Name="BtnClear"
                        Background="#7A2020"
                        Foreground="White"
                        Click="BtnClear_Click"
                        Content="清空"
                        Style="{StaticResource ToolBtn}" />
                    <Button
                        Click="BtnClose_Click"
                        Content="关闭 (Esc)"
                        Style="{StaticResource ToolBtn}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</mah:MetroWindow>
