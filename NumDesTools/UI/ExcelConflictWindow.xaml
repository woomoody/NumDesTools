<Window
    x:Class="NumDesTools.UI.ExcelConflictWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:NumDesTools.UI"
    Title="Excel 冲突解决"
    Width="1100" Height="760" MinWidth="800" MinHeight="560"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    Background="#1E1E1E"
    KeyDown="Window_EscClose">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionBtn">
            <Setter Property="Padding"          Value="10,4"/>
            <Setter Property="Margin"           Value="4,0"/>
            <Setter Property="Background"       Value="#333"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>
        <Style TargetType="Button" x:Key="ApplyBtn">
            <Setter Property="Padding"          Value="14,6"/>
            <Setter Property="Background"       Value="#1A5C3A"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontWeight"       Value="Bold"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Padding"    Value="10,4"/>
        </Style>
    </Window.Resources>

    <!--
        行布局:
          0   顶部工具栏
          1   Sheet Tabs + 列头
          2   冲突行列表 (*)
          3   冲突行横向滚动条          ← 仅冲突行，随隐藏列动态变化
          4   加载更多工具栏
          5   拖拽条
          6   我的新增
          7   拖拽条
          8   他的新增
          9   新增/删除横向滚动条       ← 仅新增/删除行，全列
         10   拖拽条
         11   详情面板
         12   底部状态栏
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="5"/>
            <RowDefinition x:Name="RowOnlyOurs"   Height="28" MinHeight="28"/>
            <RowDefinition Height="5"/>
            <RowDefinition x:Name="RowOnlyTheirs" Height="28" MinHeight="28"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="5"/>
            <RowDefinition x:Name="RowDetail"     Height="180" MinHeight="28"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ 顶部工具栏 ══ -->
        <Border Grid.Row="0" Background="#252525" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="#888" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0">文件:</TextBlock>
                    <TextBlock x:Name="FileNameText" Foreground="White" FontSize="12"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                               MaxWidth="300" ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
                    <Separator Width="1" Background="#555" Margin="10,0"/>
                    <TextBox x:Name="FilterBox"
                             Width="180" Height="22" VerticalContentAlignment="Center"
                             Background="#2A2A2A" Foreground="White" BorderBrush="#555"
                             CaretBrush="White" FontSize="11" Padding="4,0"
                             ToolTip="输入文本或数字，筛选 ID / 备注列包含该值的冲突行"
                             KeyDown="FilterBox_KeyDown"
                             Tag="搜索 ID / 备注列…">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="搜索 ID / 备注列…" Foreground="#666" FontSize="11" Margin="5,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Button Content="筛选选中" Margin="4,0,0,0" Padding="8,3"
                            Background="#3A3A5A" Foreground="White" BorderThickness="0"
                            Cursor="Hand" FontSize="11"
                            Click="FilterSelect_Click"/>
                    <Button x:Name="FilterClearBtn" Content="清除筛选" Margin="2,0,0,0" Padding="8,3"
                            Background="#3A2A2A" Foreground="#FFAAAA" BorderThickness="0"
                            Cursor="Hand" FontSize="11" Visibility="Collapsed"
                            Click="FilterClear_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#1A1A1A" CornerRadius="3" Margin="0,0,8,0"
                            BorderBrush="#444" BorderThickness="1">
                        <StackPanel Orientation="Vertical">
                            <ToggleButton x:Name="ViewConflictOnly" Content="仅冲突"
                                          IsChecked="True"
                                          Foreground="White" Background="#1A3A6E" BorderThickness="0"
                                          Padding="10,3" Cursor="Hand" FontSize="11"
                                          Checked="ViewMode_Changed" Unchecked="ViewMode_Changed"/>
                            <Separator Height="1" Background="#333" Margin="0"/>
                            <ToggleButton x:Name="ViewContext" Content="冲突±5行"
                                          Foreground="#AAAAAA" Background="Transparent" BorderThickness="0"
                                          Padding="10,3" Cursor="Hand" FontSize="11"
                                          Checked="ViewMode_Changed" Unchecked="ViewMode_Changed"/>
                            <Separator Height="1" Background="#333" Margin="0"/>
                            <ToggleButton x:Name="ViewAll" Content="加载全部"
                                          Foreground="#AAAAAA" Background="Transparent" BorderThickness="0"
                                          Padding="10,3" Cursor="Hand" FontSize="11"
                                          Checked="ViewMode_Changed" Unchecked="ViewMode_Changed"/>
                        </StackPanel>
                    </Border>
                    <Separator Width="1" Background="#555" Margin="0,0,8,0"/>
                    <ToggleButton x:Name="HideNoConflictCols" Content="隐藏无冲突列"
                                  IsChecked="True"
                                  Foreground="White" Background="#2A4A2A" BorderThickness="1"
                                  BorderBrush="#4A6A4A" Padding="10,3" Cursor="Hand" FontSize="11"
                                  Margin="0,0,8,0"
                                  Checked="HideNoConflictCols_Changed" Unchecked="HideNoConflictCols_Changed"/>
                    <Separator Width="1" Background="#555" Margin="0,0,8,0"/>
                    <Button Content="全文件取我的"  Style="{StaticResource ActionBtn}" Click="AllOurs_Click"/>
                    <Button Content="全文件取他的"  Style="{StaticResource ActionBtn}" Click="AllTheirs_Click"/>
                    <Separator Width="1" Background="#555" Margin="4,0"/>
                    <!-- 拖拽多选操作条，有选中行时才显示 -->
                    <Border x:Name="SelectionActionBar" Visibility="Collapsed"
                            Background="#2A2A3A" CornerRadius="3" Padding="4,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="SelectionCountText" Foreground="#AAAAFF"
                                       FontSize="11" VerticalAlignment="Center" Margin="4,0,8,0"/>
                            <Button Content="选中取我的"
                                    Style="{StaticResource ActionBtn}" Background="#1A3A6E"
                                    Click="SelectedOurs_Click"/>
                            <Button Content="选中取他的"
                                    Style="{StaticResource ActionBtn}" Background="#1A5C3A"
                                    Click="SelectedTheirs_Click"/>
                            <Button Content="✕" ToolTip="清除选中"
                                    Style="{StaticResource ActionBtn}" Background="#3A2A2A"
                                    Padding="6,4" Click="SelectedClear_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Sheet Tabs + 置顶列头 ══ -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TabControl x:Name="SheetTabs" Grid.Row="0" Background="#1E1E1E" BorderThickness="0"
                        SelectionChanged="SheetTabs_SelectionChanged"/>

            <Border Grid.Row="1" x:Name="ColBatchBar" Background="#1A1A2A"
                    BorderBrush="#333" BorderThickness="0,0,0,1" Visibility="Collapsed">
                <ScrollViewer x:Name="BatchScroll"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ColBatchPanel" Orientation="Vertical"/>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="2" Background="#111" BorderBrush="#333" BorderThickness="0,0,0,1">
                <ScrollViewer x:Name="MetaScroll"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Grid x:Name="MetaFieldGrid"  MinHeight="20"/>
                        <Grid x:Name="MetaLabelGrid"  MinHeight="20"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ══ 冲突行列表（Grid Row=* → 虚拟化正常） ══ -->
        <ListBox x:Name="ConflictList" Grid.Row="2"
                 Background="#1E1E1E" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Standard"
                 VirtualizingPanel.ScrollUnit="Item"
                 ui:ConflictRowItem.CellSelected="OnCellSelected"
                 ui:ConflictRowItem.RowDeSelected="OnRowDeSelected">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding"                    Value="0"/>
                    <Setter Property="Background"                 Value="Transparent"/>
                    <Setter Property="BorderThickness"            Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <ui:ConflictRowItem DataContext="{Binding}"
                                        ui:ConflictRowItem.CellSelected="OnCellSelected"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 冲突行专用横向滚动条（随隐藏列变化） -->
        <ScrollBar x:Name="SharedHScrollBar" Grid.Row="3"
                   Orientation="Horizontal" Height="12"
                   Minimum="0" Maximum="0" ViewportSize="100"
                   Background="#1A1A1A"
                   Scroll="SharedHScrollBar_Scroll"/>

        <!-- 全量模式分批加载工具栏 -->
        <Border x:Name="LoadMoreBar" Grid.Row="4" Visibility="Collapsed"
                Background="#1E1E2E" BorderBrush="#333" BorderThickness="0,1,0,0" Padding="6,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="LoadMoreStatus" Grid.Column="0"
                           Foreground="#AAAACC" FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="LoadMoreBtn" Content="加载更多(200行)"
                            Click="LoadMore_Click"
                            Background="#2A2A3A" Foreground="#AAAACC"
                            BorderThickness="0" Padding="10,4" Margin="0,0,4,0"
                            Cursor="Hand" FontSize="11"/>
                    <Button x:Name="LoadAllBtn" Content="加载全部"
                            Click="LoadAll_Click"
                            Background="#3A2A2A" Foreground="#FFAAAA"
                            BorderThickness="0" Padding="10,4"
                            Cursor="Hand" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 冲突 / 新增 之间的拖拽条 -->
        <GridSplitter Grid.Row="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="#3A3A3A" Cursor="SizeNS" ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- ══ 我的新增 section ══ -->
        <Border Grid.Row="6" BorderBrush="#3A3A3A" BorderThickness="0,1,0,0">
            <Grid ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>   <!-- 标题栏，始终可见 -->
                    <RowDefinition Height="Auto"/> <!-- 列头，展开时出现 -->
                    <RowDefinition Height="*"/>    <!-- 列表，展开时占满 -->
                </Grid.RowDefinitions>

                <!-- 标题栏 -->
                <Border Grid.Row="0" x:Name="SectionOnlyOursHeader" Background="#2A1010"
                        Cursor="Hand" MouseLeftButtonDown="SectionHeader_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <TextBlock x:Name="SectionOnlyOursChevron" Text="▶ " Foreground="#FF8888" FontSize="11"/>
                        <TextBlock Text="我的新增" Foreground="#FF8888" FontSize="11" FontWeight="Bold"/>
                        <TextBlock x:Name="SectionOnlyOursCount" Foreground="#666" FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 列头（展开时） -->
                <Border Grid.Row="1" x:Name="OursHeaderBorder" Visibility="Collapsed"
                        Background="#111" BorderBrush="#333" BorderThickness="0,0,0,1">
                    <ScrollViewer x:Name="OursMetaScroll"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Grid x:Name="OursMetaFieldGrid" MinHeight="20"/>
                            <Grid x:Name="OursMetaLabelGrid" MinHeight="20"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- 列表（展开时，虚拟化正常） -->
                <ListBox x:Name="OnlyOursList" Grid.Row="2"
                         Background="#1A0808" BorderThickness="0"
                         Visibility="Collapsed"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Standard"
                         VirtualizingPanel.ScrollUnit="Item"
                         ui:ConflictRowItem.CellSelected="OnCellSelected">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding"                    Value="0"/>
                            <Setter Property="Background"                 Value="Transparent"/>
                            <Setter Property="BorderThickness"            Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <ui:ConflictRowItem DataContext="{Binding}"
                                                ui:ConflictRowItem.CellSelected="OnCellSelected"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 新增 / 删除 之间的拖拽条 -->
        <GridSplitter Grid.Row="7" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="#3A3A3A" Cursor="SizeNS" ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- ══ 他的新增 section ══ -->
        <Border Grid.Row="8" BorderBrush="#3A3A3A" BorderThickness="0,1,0,0">
            <Grid ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" x:Name="SectionOnlyTheirsHeader" Background="#0A2010"
                        Cursor="Hand" MouseLeftButtonDown="SectionHeader_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <TextBlock x:Name="SectionOnlyTheirsChevron" Text="▶ " Foreground="#88FF88" FontSize="11"/>
                        <TextBlock Text="他的新增" Foreground="#88FF88" FontSize="11" FontWeight="Bold"/>
                        <TextBlock x:Name="SectionOnlyTheirsCount" Foreground="#666" FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" x:Name="TheirsHeaderBorder" Visibility="Collapsed"
                        Background="#111" BorderBrush="#333" BorderThickness="0,0,0,1">
                    <ScrollViewer x:Name="TheirsMetaScroll"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Grid x:Name="TheirsMetaFieldGrid" MinHeight="20"/>
                            <Grid x:Name="TheirsMetaLabelGrid" MinHeight="20"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <ListBox x:Name="OnlyTheirsList" Grid.Row="2"
                         Background="#080A08" BorderThickness="0"
                         Visibility="Collapsed"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Standard"
                         VirtualizingPanel.ScrollUnit="Item"
                         ui:ConflictRowItem.CellSelected="OnCellSelected">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding"                    Value="0"/>
                            <Setter Property="Background"                 Value="Transparent"/>
                            <Setter Property="BorderThickness"            Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <ui:ConflictRowItem DataContext="{Binding}"
                                                ui:ConflictRowItem.CellSelected="OnCellSelected"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 新增/删除行专用横向滚动条（全列） -->
        <ScrollBar x:Name="RowsHScrollBar" Grid.Row="9"
                   Orientation="Horizontal" Height="12"
                   Minimum="0" Maximum="0" ViewportSize="100"
                   Background="#1A1A1A"
                   Scroll="RowsHScrollBar_Scroll"/>

        <!-- 滚动条 / 详情 之间的拖拽条 -->
        <GridSplitter Grid.Row="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="#3A3A3A" Cursor="SizeNS" ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- ══ 详情面板 ══ -->
        <Border Grid.Row="11" Background="#161616" BorderBrush="#3A3A3A" BorderThickness="0,1,0,0">
            <Grid ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>   <!-- 标题栏 -->
                    <RowDefinition Height="*"/>    <!-- 内容 -->
                </Grid.RowDefinitions>

                <!-- 标题栏（可点击折叠） -->
                <Border Grid.Row="0" x:Name="DetailHeaderBar" Background="#1A2A1A"
                        Cursor="Hand" MouseLeftButtonDown="DetailHeader_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <TextBlock x:Name="DetailChevron" Text="▼ " Foreground="#88FF88" FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="详情" Foreground="#88FF88" FontSize="11" FontWeight="Bold"/>
                        <TextBlock x:Name="DetailRowKey" Foreground="#A8C8FF" FontSize="11" Margin="8,0,0,0"/>
                        <TextBlock x:Name="DetailHint" Foreground="#555" FontSize="10"
                                   Margin="12,0,0,0" Text="点击任意行查看完整值对比"/>
                    </StackPanel>
                </Border>

                <!-- 内容（变更导航 + 字段对比） -->
                <Grid Grid.Row="1" x:Name="DetailContent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" MinWidth="150" MaxWidth="500"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#111" BorderBrush="#333" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#1A1A1A" Padding="6,4">
                                <TextBlock Foreground="#888" FontSize="10">变更导航（当前Sheet）</TextBlock>
                            </Border>
                            <ListBox x:Name="ChangeNavList" Grid.Row="1"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     SelectionChanged="ChangeNavList_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding"     Value="0"/>
                                        <Setter Property="Background"  Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#1A3A6E"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#252535"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                  Background="#2A2A2A" Cursor="SizeWE" ResizeDirection="Columns"/>

                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <StackPanel x:Name="DetailPanel" Margin="4"/>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!-- ══ 底部状态栏 ══ -->
        <Border Grid.Row="12" Background="#252525" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="#888" FontSize="12">冲突行: </TextBlock>
                    <TextBlock x:Name="StatRows"  Foreground="White" FontSize="12" Margin="0,0,16,0"/>
                    <TextBlock Foreground="#888"  FontSize="12">冲突格: </TextBlock>
                    <TextBlock x:Name="StatCells" Foreground="White" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="取消" Style="{StaticResource ActionBtn}" Click="Cancel_Click"/>
                    <Button x:Name="ApplyButton" Content="✓ 应用并 git add"
                            Style="{StaticResource ApplyBtn}" Click="Apply_Click"
                            IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
