<Window
    x:Class="NumDesTools.UI.ExcelConflictWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:NumDesTools.UI"
    Title="Excel 冲突解决"
    Width="1100" Height="760" MinWidth="800" MinHeight="560"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    Background="#1E1E1E"
    KeyDown="Window_EscClose">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionBtn">
            <Setter Property="Padding"          Value="10,4"/>
            <Setter Property="Margin"           Value="4,0"/>
            <Setter Property="Background"       Value="#333"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>
        <Style TargetType="Button" x:Key="ApplyBtn">
            <Setter Property="Padding"          Value="14,6"/>
            <Setter Property="Background"       Value="#1A5C3A"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontWeight"       Value="Bold"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Padding"    Value="10,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0: 顶部工具栏 -->
            <RowDefinition Height="Auto"/>   <!-- 1: Sheet Tabs + 列头 -->
            <RowDefinition Height="*"/>      <!-- 2: 主列表 -->
            <RowDefinition Height="Auto"/>   <!-- 3: 共享横向滚动条 -->
            <RowDefinition Height="5"/>      <!-- 4: 分隔拖拽条 -->
            <RowDefinition x:Name="DetailRow" Height="160" MinHeight="60" MaxHeight="360"/> <!-- 5: 详情面板 -->
            <RowDefinition Height="Auto"/>   <!-- 6: 底部状态栏 -->
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="#252525" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="#888" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0">文件:</TextBlock>
                    <TextBlock x:Name="FileNameText" Foreground="White" FontSize="12"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                               MaxWidth="500" ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 视图模式：垂直堆叠的三档切换 -->
                    <Border Background="#1A1A1A" CornerRadius="3" Margin="0,0,8,0"
                            BorderBrush="#444" BorderThickness="1">
                        <StackPanel Orientation="Vertical">
                            <ToggleButton x:Name="ViewConflictOnly" Content="仅冲突"
                                          IsChecked="True"
                                          Foreground="White" Background="#1A3A6E" BorderThickness="0"
                                          Padding="10,3" Cursor="Hand" FontSize="11"
                                          Checked="ViewMode_Changed" Unchecked="ViewMode_Changed"/>
                            <Separator Height="1" Background="#333" Margin="0"/>
                            <ToggleButton x:Name="ViewContext" Content="冲突±5行"
                                          Foreground="#AAAAAA" Background="Transparent" BorderThickness="0"
                                          Padding="10,3" Cursor="Hand" FontSize="11"
                                          Checked="ViewMode_Changed" Unchecked="ViewMode_Changed"/>
                            <Separator Height="1" Background="#333" Margin="0"/>
                            <ToggleButton x:Name="ViewAll" Content="加载全部"
                                          Foreground="#AAAAAA" Background="Transparent" BorderThickness="0"
                                          Padding="10,3" Cursor="Hand" FontSize="11"
                                          Checked="ViewMode_Changed" Unchecked="ViewMode_Changed"/>
                        </StackPanel>
                    </Border>
                    <Separator Width="1" Background="#555" Margin="0,0,8,0"/>
                    <Button Content="全文件取我的"  Style="{StaticResource ActionBtn}" Click="AllOurs_Click"/>
                    <Button Content="全文件取他的"  Style="{StaticResource ActionBtn}" Click="AllTheirs_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sheet Tabs + 置顶字段/说明头 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TabControl x:Name="SheetTabs" Grid.Row="0" Background="#1E1E1E" BorderThickness="0"
                        SelectionChanged="SheetTabs_SelectionChanged"/>

            <!-- 列批量选择栏（与 MetaScroll 水平同步） -->
            <Border Grid.Row="1" x:Name="ColBatchBar" Background="#1A1A2A"
                    BorderBrush="#333" BorderThickness="0,0,0,1"
                    Visibility="Collapsed">
                <ScrollViewer x:Name="BatchScroll"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ColBatchPanel" Orientation="Vertical"/>
                </ScrollViewer>
            </Border>

            <!-- 置顶 Meta 头 -->
            <Border Grid.Row="2" Background="#111" BorderBrush="#333" BorderThickness="0,0,0,1">
                <ScrollViewer x:Name="MetaScroll"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Grid x:Name="MetaFieldGrid"  MinHeight="20"/>
                        <Grid x:Name="MetaLabelGrid"  MinHeight="20"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 冲突行列表（VirtualizingStackPanel 保证大数据不卡） -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ListBox x:Name="ConflictList" Grid.Row="0"
                     Background="#1E1E1E" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Standard"
                     VirtualizingPanel.ScrollUnit="Item"
                     ui:ConflictRowItem.CellSelected="OnCellSelected">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding"                    Value="0"/>
                        <Setter Property="Background"                 Value="Transparent"/>
                        <Setter Property="BorderThickness"            Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <!-- 去掉选中高亮，内容直接透传 -->
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <ui:ConflictRowItem DataContext="{Binding}"
                                            ui:ConflictRowItem.CellSelected="OnCellSelected"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 全量模式分批加载工具栏 -->
            <Border x:Name="LoadMoreBar" Grid.Row="1" Visibility="Collapsed"
                    Background="#1E1E2E" BorderBrush="#333" BorderThickness="0,1,0,0"
                    Padding="6,4" Margin="0,2,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="LoadMoreStatus" Grid.Column="0"
                               Foreground="#AAAACC" FontSize="11"
                               VerticalAlignment="Center" Margin="4,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="LoadMoreBtn"    Content="加载更多(200行)"
                                Click="LoadMore_Click"
                                Background="#2A2A3A" Foreground="#AAAACC"
                                BorderThickness="0" Padding="10,4" Margin="0,0,4,0"
                                Cursor="Hand" FontSize="11"/>
<Button x:Name="LoadAllBtn"     Content="加载全部"
                                Click="LoadAll_Click"
                                Background="#3A2A2A" Foreground="#FFAAAA"
                                BorderThickness="0" Padding="10,4"
                                Cursor="Hand" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- 共享横向滚动条（所有冲突行公用） -->
        <ScrollBar x:Name="SharedHScrollBar" Grid.Row="3"
                   Orientation="Horizontal" Height="12"
                   Minimum="0" Maximum="0" ViewportSize="100"
                   Background="#1A1A1A"
                   Scroll="SharedHScrollBar_Scroll"/>

        <!-- 可拖拽分隔条 -->
        <GridSplitter Grid.Row="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="#444" Cursor="SizeNS" ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- 详情面板 -->
        <Border Grid.Row="5" Background="#161616" BorderBrush="#333" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 详情标题栏 -->
                <Border Grid.Row="0" Background="#1E2D1E" Padding="10,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="#88FF88" FontSize="11" FontWeight="Bold" VerticalAlignment="Center">▼ 详情</TextBlock>
                        <TextBlock x:Name="DetailRowKey" Foreground="#A8C8FF" FontSize="11"
                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="DetailHint"   Foreground="#555" FontSize="10"
                                   Margin="12,0,0,0" VerticalAlignment="Center"
                                   Text="点击任意行查看完整值对比"/>
                    </StackPanel>
                </Border>

                <!-- 详情内容：左侧变更导航 + 右侧字段对比 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" MinWidth="150" MaxWidth="500"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧变更导航 -->
                    <Border Grid.Column="0" Background="#111" BorderBrush="#333" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#1A1A1A" Padding="6,4">
                                <TextBlock Foreground="#888" FontSize="10">变更导航（当前Sheet）</TextBlock>
                            </Border>
                            <ListBox x:Name="ChangeNavList" Grid.Row="1"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     SelectionChanged="ChangeNavList_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding"     Value="0"/>
                                        <Setter Property="Background"  Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#1A3A6E"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#252535"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- 拖拽分隔 -->
                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                  Background="#2A2A2A" Cursor="SizeWE" ResizeDirection="Columns"/>

                    <!-- 右侧字段对比 -->
                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <StackPanel x:Name="DetailPanel" Margin="4"/>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!-- 底部状态栏 -->
        <Border Grid.Row="6" Background="#252525" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="#888" FontSize="12">冲突行: </TextBlock>
                    <TextBlock x:Name="StatRows"  Foreground="White" FontSize="12" Margin="0,0,16,0"/>
                    <TextBlock Foreground="#888"  FontSize="12">冲突格: </TextBlock>
                    <TextBlock x:Name="StatCells" Foreground="White" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="取消" Style="{StaticResource ActionBtn}" Click="Cancel_Click"/>
                    <Button x:Name="ApplyButton" Content="✓ 应用并 git add"
                            Style="{StaticResource ApplyBtn}" Click="Apply_Click"
                            IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
