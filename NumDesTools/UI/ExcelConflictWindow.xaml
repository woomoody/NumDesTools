<Window
    x:Class="NumDesTools.UI.ExcelConflictWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:NumDesTools.UI"
    Title="Excel 冲突解决"
    Width="1100" Height="760" MinWidth="800" MinHeight="560"
    WindowStartupLocation="CenterScreen"
    Background="#1E1E1E">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionBtn">
            <Setter Property="Padding"          Value="10,4"/>
            <Setter Property="Margin"           Value="4,0"/>
            <Setter Property="Background"       Value="#333"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>
        <Style TargetType="Button" x:Key="ApplyBtn">
            <Setter Property="Padding"          Value="14,6"/>
            <Setter Property="Background"       Value="#1A5C3A"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontWeight"       Value="Bold"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Padding"    Value="10,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 顶部工具栏 -->
            <RowDefinition Height="Auto"/>   <!-- Sheet Tabs + 列头 -->
            <RowDefinition Height="*"/>      <!-- 主列表 -->
            <RowDefinition Height="Auto"/>   <!-- 分隔拖拽条 -->
            <RowDefinition x:Name="DetailRow" Height="160" MinHeight="60" MaxHeight="360"/> <!-- 详情面板 -->
            <RowDefinition Height="Auto"/>   <!-- 底部状态栏 -->
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="#252525" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="#888" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0">文件:</TextBlock>
                    <TextBlock x:Name="FileNameText" Foreground="White" FontSize="12"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                               MaxWidth="500" ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="全文件取我的"  Style="{StaticResource ActionBtn}" Click="AllOurs_Click"/>
                    <Button Content="全文件取他的"  Style="{StaticResource ActionBtn}" Click="AllTheirs_Click"/>
                    <Separator Width="1" Background="#555" Margin="8,0"/>
                    <ToggleButton x:Name="OnlyConflictToggle" Content="仅看冲突行"
                                  Foreground="White" Background="#333" BorderThickness="0"
                                  Padding="10,4" Margin="4,0" Cursor="Hand"
                                  Checked="FilterToggle_Changed" Unchecked="FilterToggle_Changed"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sheet Tabs + 置顶字段/说明头 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TabControl x:Name="SheetTabs" Grid.Row="0" Background="#1E1E1E" BorderThickness="0"
                        SelectionChanged="SheetTabs_SelectionChanged"/>

            <!-- 列批量选择栏 -->
            <Border Grid.Row="1" x:Name="ColBatchBar" Background="#1A1A2A"
                    BorderBrush="#333" BorderThickness="0,0,0,1" Padding="8,4"
                    Visibility="Collapsed">
                <WrapPanel x:Name="ColBatchPanel" VerticalAlignment="Center">
                    <TextBlock Text="列批量:" Foreground="#888" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                </WrapPanel>
            </Border>

            <!-- 置顶 Meta 头 -->
            <Border Grid.Row="2" Background="#111" BorderBrush="#333" BorderThickness="0,0,0,1">
                <ScrollViewer x:Name="MetaScroll"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Grid x:Name="MetaFieldGrid"  MinHeight="20"/>
                        <Grid x:Name="MetaLabelGrid"  MinHeight="20"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 冲突行列表 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#1E1E1E">
            <ItemsControl x:Name="ConflictList" Margin="0,4"
                          ui:ConflictRowItem.CellSelected="OnCellSelected">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:ConflictRowItem DataContext="{Binding}"
                                            ui:ConflictRowItem.CellSelected="OnCellSelected"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 可拖拽分隔条 -->
        <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch"
                      Background="#444" Cursor="SizeNS" ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- 详情面板 -->
        <Border Grid.Row="4" Background="#161616" BorderBrush="#333" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 详情标题栏 -->
                <Border Grid.Row="0" Background="#1E2D1E" Padding="10,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="#88FF88" FontSize="11" FontWeight="Bold" VerticalAlignment="Center">▼ 详情</TextBlock>
                        <TextBlock x:Name="DetailRowKey" Foreground="#A8C8FF" FontSize="11"
                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="DetailHint"   Foreground="#555" FontSize="10"
                                   Margin="12,0,0,0" VerticalAlignment="Center"
                                   Text="点击任意行查看完整值对比"/>
                    </StackPanel>
                </Border>

                <!-- 详情内容：由 code-behind 动态构建，支持字符级高亮 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailPanel" Margin="4"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 底部状态栏 -->
        <Border Grid.Row="5" Background="#252525" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="#888" FontSize="12">冲突行: </TextBlock>
                    <TextBlock x:Name="StatRows"  Foreground="White" FontSize="12" Margin="0,0,16,0"/>
                    <TextBlock Foreground="#888"  FontSize="12">冲突格: </TextBlock>
                    <TextBlock x:Name="StatCells" Foreground="White" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="取消" Style="{StaticResource ActionBtn}" Click="Cancel_Click"/>
                    <Button x:Name="ApplyButton" Content="✓ 应用并 git add"
                            Style="{StaticResource ApplyBtn}" Click="Apply_Click"
                            IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
