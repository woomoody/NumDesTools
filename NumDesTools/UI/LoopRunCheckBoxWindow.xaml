<mah:MetroWindow
    x:Class="NumDesTools.UI.LoopRunCheckBoxWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    Title="计算选项"
    Width="500" Height="500"
    WindowStartupLocation="CenterScreen"
    KeyDown="Window_EscClose">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <StackPanel Name="SpecialCheckBoxContainer" Margin="5">
                    <CheckBox Margin="5"
                              Checked="SelectAllCheckBox_Checked"
                              Content="全选/取消"
                              Tag="全选"
                              Unchecked="SelectAllCheckBox_Unchecked" />
                    <CheckBox Margin="5"
                              Checked="InvertSelectionCheckBox_Checked"
                              Content="反选"
                              Tag="反选" />
                </StackPanel>
                <Separator Margin="5" />
                <StackPanel Name="CheckBoxContainer" Margin="5" />
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="1" Margin="5"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="100" Height="30" Margin="5"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    Click="GetCurrentCheckBox_Click"
                    Content="计算随机数" />
        </StackPanel>
    </Grid>
</mah:MetroWindow>
