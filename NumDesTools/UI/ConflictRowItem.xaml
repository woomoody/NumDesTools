<UserControl
    x:Class="NumDesTools.UI.ConflictRowItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border BorderBrush="#333" BorderThickness="0,0,0,1" Margin="0,0,0,2">
        <StackPanel>

            <!-- 行头：ID + 类型 + 操作按钮 -->
            <Grid x:Name="HeaderGrid" Background="#2A2A2A" MinHeight="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,3">
                    <!-- 剔除按钮：仅筛选选中模式下可见 -->
                    <Button x:Name="DeSelectBtn" Content="✕" ToolTip="从选中中剔除此行"
                            Visibility="Collapsed"
                            Padding="3,1" Margin="0,0,4,0" FontSize="10"
                            Background="#5A2A2A" Foreground="#FFAAAA" BorderThickness="0"
                            Cursor="Hand" Click="DeSelect_Click"/>
                    <TextBlock Text="ID: " Foreground="#888" FontSize="11"/>
                    <TextBlock x:Name="RowKeyText" Foreground="White" FontWeight="Bold" FontSize="11"/>
                    <StackPanel x:Name="RowHashCols" Orientation="Horizontal"
                                Margin="8,0,0,0" VerticalAlignment="Center"/>
                    <Border x:Name="BadgeBorder" CornerRadius="3" Margin="8,0,0,0" Padding="4,1">
                        <TextBlock x:Name="DiffTypeBadge" FontSize="10"/>
                    </Border>
                </StackPanel>

                <!-- Modified 行：格级全取按钮 -->
                <StackPanel x:Name="BatchButtons" Grid.Column="1" Orientation="Horizontal"
                            Margin="0,2,8,2" VerticalAlignment="Center">
                    <Button Content="全取我的"  Tag="Ours"   Click="BatchChoice_Click"
                            Padding="6,2" Margin="0,0,4,0"
                            Background="#1A3A6E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="全取他的" Tag="Theirs" Click="BatchChoice_Click"
                            Padding="6,2"
                            Background="#1A5C3A" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>

                <!-- OnlyOurs / OnlyTheirs 行：行级选择 -->
                <StackPanel x:Name="RowChoicePanel" Grid.Column="1" Orientation="Horizontal"
                            Margin="0,2,8,2" VerticalAlignment="Center" Visibility="Collapsed">
                    <CheckBox x:Name="RowChoiceOursRb"   Content="保留我的"
                              Foreground="#A8C8FF" Margin="0,0,10,0" FontSize="11"
                              Background="Transparent" BorderBrush="#A8C8FF"/>
                    <CheckBox x:Name="RowChoiceTheirsRb" Content="用他的"
                              Foreground="#A8FFCA" FontSize="11"
                              Background="Transparent" BorderBrush="#A8FFCA"/>
                </StackPanel>
            </Grid>

            <!-- OURS 行 -->
            <ScrollViewer x:Name="OursScroll"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled"
                          Height="24">
                <Grid x:Name="OursGrid" Height="24"/>
            </ScrollViewer>

            <!-- THEIRS 行（OnlyOurs 时隐藏） -->
            <ScrollViewer x:Name="TheirsScroll"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled"
                          Height="24">
                <Grid x:Name="TheirsGrid" Height="24"/>
            </ScrollViewer>

        </StackPanel>
    </Border>
</UserControl>
