<UserControl
    x:Class="NumDesTools.UI.BatchReplacePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">

    <Grid Background="{Binding BgMain, ElementName=Root}" KeyDown="Grid_KeyDown">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" MinWidth="100"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ 左侧历史 ══ -->
        <Grid Grid.Column="0" Background="{Binding BgPanel, ElementName=Root}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="历史记录"
                       Foreground="{Binding FgDim, ElementName=Root}"
                       FontSize="11" Margin="8,8,8,4"/>
            <ListBox x:Name="HistoryList" Grid.Row="1"
                     Background="Transparent" BorderThickness="0"
                     SelectionChanged="HistoryList_SelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Foreground" Value="{Binding FgDim, ElementName=Root}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{Binding BgInput, ElementName=Root}"/>
                                <Setter Property="Foreground" Value="{Binding FgMain, ElementName=Root}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{Binding AccentCol, ElementName=Root}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Display}" TextTrimming="CharacterEllipsis"
                                       FontSize="11" ToolTip="{Binding Detail}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="✕" FontSize="9"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{Binding FgDim, ElementName=Root}"
                                    Padding="4,1" Margin="4,0,0,0"
                                    Tag="{Binding}"
                                    Click="DeleteHistory_Click"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Button Grid.Row="2" Content="清空历史"
                    Background="{Binding BgPanel, ElementName=Root}"
                    Foreground="{Binding FgMain, ElementName=Root}"
                    BorderBrush="{Binding BorderCol, ElementName=Root}"
                    Margin="6,4,6,6" Padding="10,4" Click="ClearHistory_Click"/>
        </Grid>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                      Background="{Binding BorderCol, ElementName=Root}"/>

        <!-- ══ 右侧编辑区 ══ -->
        <Grid Grid.Column="2" Margin="10,8,10,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Foreground="{Binding FgDim, ElementName=Root}" FontSize="11"
                       Margin="0,0,0,6" TextWrapping="Wrap"
                       Text="每行一对：查找值 → 替换值（Ctrl+Enter 执行）"/>

            <!-- 列头 -->
            <Grid Grid.Row="1" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="28"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="查找值"
                           Foreground="{Binding FgDim, ElementName=Root}"
                           FontSize="11" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="替换值"
                           Foreground="{Binding FgDim, ElementName=Root}"
                           FontSize="11" HorizontalAlignment="Center"/>
            </Grid>

            <!-- 规则行 -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="RuleRows">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <TextBox x:Name="FromBox"
                                             Background="{Binding BgInput, ElementName=Root}"
                                             Foreground="{Binding FgMain, ElementName=Root}"
                                             BorderBrush="{Binding BorderCol, ElementName=Root}"
                                             CaretBrush="{Binding FgMain, ElementName=Root}"
                                             SelectionBrush="{Binding AccentCol, ElementName=Root}"
                                             BorderThickness="1" Padding="4,3"
                                             Text="{Binding From, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas"/>
                                    <TextBlock IsHitTestVisible="False" Padding="6,4"
                                               Foreground="{Binding FgDim, ElementName=Root}"
                                               FontFamily="Consolas" FontStyle="Italic"
                                               Text="查找值...">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding From}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <TextBlock Grid.Column="1" Text="→" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding FgDim, ElementName=Root}"/>
                                <TextBox Grid.Column="2"
                                         Background="{Binding BgInput, ElementName=Root}"
                                         Foreground="{Binding FgMain, ElementName=Root}"
                                         BorderBrush="{Binding BorderCol, ElementName=Root}"
                                         CaretBrush="{Binding FgMain, ElementName=Root}"
                                         SelectionBrush="{Binding AccentCol, ElementName=Root}"
                                         BorderThickness="1" Padding="4,3"
                                         Text="{Binding To, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas"/>
                                <Button Grid.Column="3" Content="✕" FontSize="10" Margin="2,0,0,0"
                                        Background="{Binding BgPanel, ElementName=Root}"
                                        Foreground="{Binding FgMain, ElementName=Root}"
                                        BorderBrush="{Binding BorderCol, ElementName=Root}"
                                        Padding="4,3" Tag="{Binding}" Click="RemoveRow_Click"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Button Grid.Row="3" Content="+ 添加一行"
                    Background="{Binding BgPanel, ElementName=Root}"
                    Foreground="{Binding FgMain, ElementName=Root}"
                    BorderBrush="{Binding BorderCol, ElementName=Root}"
                    HorizontalAlignment="Left" Margin="0,6,0,6" Padding="8,3"
                    Click="AddRow_Click"/>

            <!-- 状态 + 按钮 -->
            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="StatusText" Grid.Row="0" FontSize="11" Margin="0,0,0,6"
                           Foreground="{Binding FgDim, ElementName=Root}"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="执行替换 (Ctrl+Enter)"
                            Background="{Binding AccentCol, ElementName=Root}"
                            Foreground="White"
                            BorderBrush="{Binding AccentCol, ElementName=Root}"
                            BorderThickness="1" Padding="10,4"
                            Width="150" Margin="0,0,8,0" Click="Execute_Click"/>
                    <Button Content="清空"
                            Background="{Binding BgPanel, ElementName=Root}"
                            Foreground="{Binding FgMain, ElementName=Root}"
                            BorderBrush="{Binding BorderCol, ElementName=Root}"
                            Padding="10,4" Width="60" Click="Clear_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
