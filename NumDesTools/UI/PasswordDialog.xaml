<Window
    x:Class="NumDesTools.UI.PasswordDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="密码验证"
    Width="380" Height="220"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock x:Name="PromptText" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBlock FontSize="11" Foreground="#888"
                   Margin="0,0,0,10" Text="插件授权已过期，请联系作者获取密码。"
                   TextWrapping="Wrap"/>
        <PasswordBox x:Name="PasswordBox" Height="32" FontSize="14"
                     Margin="0,0,0,15" PasswordChar="*"/>
        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Width="80" IsDefault="True" Margin="0,0,10,0"
                    Click="OkButton_Click" Content="确定"/>
            <Button Width="80" IsCancel="True"
                    Click="CancelButton_Click" Content="取消"/>
        </StackPanel>
    </StackPanel>
</Window>
