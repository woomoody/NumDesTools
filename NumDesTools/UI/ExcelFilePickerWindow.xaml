<mah:MetroWindow
    x:Class="NumDesTools.UI.ExcelFilePickerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    Title="选择 Excel 文件"
    WindowStartupLocation="CenterScreen"
    SizeToContent="Manual"
    KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 搜索框 -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <TextBox x:Name="SearchBox"
                         Padding="6,4" FontSize="13"
                         TextChanged="SearchBox_TextChanged"
                         PreviewKeyDown="SearchBox_KeyDown"
                         GotFocus="SearchBox_GotFocus"
                         LostFocus="SearchBox_LostFocus"/>
                <TextBlock x:Name="SearchPlaceholder"
                           Text="输入文件名过滤…"
                           Foreground="{DynamicResource MahApps.Brushes.Gray5}"
                           FontSize="13"
                           IsHitTestVisible="False" VerticalAlignment="Center" Margin="8,0"
                           Visibility="Visible"/>
                <!-- 历史下拉 -->
                <Popup x:Name="HistoryPopup"
                       PlacementTarget="{Binding ElementName=SearchBox}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                            BorderBrush="{DynamicResource MahApps.Brushes.Gray7}"
                            BorderThickness="1" CornerRadius="3"
                            MinWidth="{Binding ActualWidth, ElementName=SearchBox}"
                            MaxHeight="300">
                        <ListBox x:Name="HistoryList"
                                 Background="Transparent"
                                 BorderThickness="0" FontSize="12" FontFamily="Consolas"
                                 MouseLeftButtonUp="HistoryList_MouseUp"
                                 KeyDown="HistoryList_KeyDown"/>
                    </Border>
                </Popup>
            </Grid>
            <TextBlock Grid.Column="1" x:Name="CountLabel"
                       Foreground="{DynamicResource MahApps.Brushes.Gray5}"
                       FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
        </Grid>

        <!-- 过滤选项 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
            <CheckBox x:Name="FilterTilde" Content="过滤 ~ 临时文件" FontSize="11"
                      IsChecked="True" Margin="0,0,16,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            <CheckBox x:Name="FilterHash" Content="过滤 # 文件" FontSize="11"
                      Margin="0,0,16,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            <CheckBox x:Name="FilterXlsm" Content="过滤 .xlsm 文件" FontSize="11"
                      Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            <TextBlock x:Name="RootLabel"
                       Foreground="{DynamicResource MahApps.Brushes.Gray5}"
                       FontSize="10"
                       VerticalAlignment="Center" Margin="20,0,0,0" TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- 文件列表 -->
        <ListBox x:Name="FileList"
                 Grid.Row="2"
                 BorderThickness="1"
                 FontSize="12" FontFamily="Consolas"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 MouseDoubleClick="FileList_DoubleClick"
                 KeyDown="FileList_KeyDown"
                 SelectionChanged="FileList_SelectionChanged"
                 PreviewMouseWheel="List_PreviewMouseWheel">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding RelPath}" ToolTip="{Binding FullPath}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 底部按钮 -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SelectedPathLabel" Grid.Column="0"
                       Foreground="{DynamicResource MahApps.Brushes.Gray5}"
                       FontSize="10" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
            <Button x:Name="CancelBtn" Grid.Column="1" Content="取消"
                    Width="80" Height="28" Margin="0,0,8,0"
                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                    Click="Cancel_Click"/>
            <Button x:Name="OkBtn" Grid.Column="2" Content="确定"
                    Width="80" Height="28"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    Click="Ok_Click"/>
        </Grid>
    </Grid>
</mah:MetroWindow>
