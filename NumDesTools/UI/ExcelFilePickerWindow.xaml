<Window
    x:Class="NumDesTools.UI.ExcelFilePickerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="选择 Excel 文件"
    Width="640" Height="500"
    MinWidth="400" MinHeight="300"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    Background="#1E1E1E" Foreground="#DDDDDD"
    KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 搜索框 -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <TextBox x:Name="SearchBox"
                         Background="#2D2D2D" Foreground="#DDDDDD" CaretBrush="#DDDDDD"
                         BorderBrush="#555" BorderThickness="1"
                         Padding="6,4" FontSize="13"
                         TextChanged="SearchBox_TextChanged"
                         KeyDown="SearchBox_KeyDown"
                         GotFocus="SearchBox_GotFocus"
                         LostFocus="SearchBox_LostFocus">
                    <TextBox.Resources>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3">
                                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                <TextBlock x:Name="SearchPlaceholder"
                           Text="输入文件名过滤…" Foreground="#666" FontSize="13"
                           IsHitTestVisible="False" VerticalAlignment="Center" Margin="8,0"
                           Visibility="Visible"/>
                <!-- 历史下拉 -->
                <Popup x:Name="HistoryPopup"
                       PlacementTarget="{Binding ElementName=SearchBox}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="#2D2D2D" BorderBrush="#555" BorderThickness="1" CornerRadius="3"
                            MinWidth="{Binding ActualWidth, ElementName=SearchBox}"
                            MaxHeight="300">
                        <ListBox x:Name="HistoryList"
                                 Background="Transparent" Foreground="#DDDDDD"
                                 BorderThickness="0" FontSize="12" FontFamily="Consolas"
                                 MouseLeftButtonUp="HistoryList_MouseUp"
                                 KeyDown="HistoryList_KeyDown">
                            <ListBox.Resources>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,4"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#DDDDDD"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#1A3A6E"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3A3A5A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Resources>
                        </ListBox>
                    </Border>
                </Popup>
            </Grid>
            <TextBlock Grid.Column="1" x:Name="CountLabel"
                       Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
        </Grid>

        <!-- 过滤选项 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
            <CheckBox x:Name="FilterTilde" Content="过滤 ~ 临时文件" Foreground="#AAAAAA" FontSize="11"
                      IsChecked="True" Margin="0,0,16,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            <CheckBox x:Name="FilterHash" Content="过滤 # 文件" Foreground="#AAAAAA" FontSize="11"
                      Margin="0,0,16,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            <CheckBox x:Name="FilterXlsm" Content="过滤 .xlsm 文件" Foreground="#AAAAAA" FontSize="11"
                      Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            <TextBlock x:Name="RootLabel" Foreground="#555" FontSize="10"
                       VerticalAlignment="Center" Margin="20,0,0,0" TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- 文件列表 -->
        <ListBox x:Name="FileList"
                 Grid.Row="2"
                 Background="#252525" Foreground="#DDDDDD"
                 BorderBrush="#444" BorderThickness="1"
                 FontSize="12" FontFamily="Consolas"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 MouseDoubleClick="FileList_DoubleClick"
                 KeyDown="FileList_KeyDown"
                 SelectionChanged="FileList_SelectionChanged">
            <ListBox.Resources>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#DDDDDD"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#1A3A6E"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2A2A3E"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.Resources>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding RelPath}" ToolTip="{Binding FullPath}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 底部按钮 -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SelectedPathLabel" Grid.Column="0"
                       Foreground="#888" FontSize="10" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
            <Button x:Name="CancelBtn" Grid.Column="1" Content="取消"
                    Width="80" Height="28" Margin="0,0,8,0"
                    Background="#3A3A3A" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="Cancel_Click"/>
            <Button x:Name="OkBtn" Grid.Column="2" Content="确定"
                    Width="80" Height="28"
                    Background="#1A3A6E" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="Ok_Click"/>
        </Grid>
    </Grid>
</Window>
