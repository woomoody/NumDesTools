<Window
    x:Class="NumDesTools.UI.WpfUiTestWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="WPF-UI 测试（普通 Window + Dark.xaml）"
    Width="400" Height="260"
    WindowStartupLocation="CenterScreen"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <StackPanel Margin="16">
        <TextBlock Text="WPF-UI 控件（普通 Window）" FontSize="16" Margin="0,0,0,12"/>
        <ui:TextBox PlaceholderText="输入框" Margin="0,0,0,8"/>
        <ui:Button Content="按钮" Width="80" HorizontalAlignment="Left"/>
    </StackPanel>
</Window>
