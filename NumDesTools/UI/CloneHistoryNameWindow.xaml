<Window
    x:Class="NumDesTools.UI.CloneHistoryNameWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="命名此次克隆"
    Width="480" Height="280" MinWidth="360" MinHeight="220"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    Background="#1E1E1E"
    FontFamily="微软雅黑"
    KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Padding"         Value="16,6"/>
            <Setter Property="Background"      Value="#1A5C3A"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="13"/>
        </Style>
        <Style TargetType="Button" x:Key="SecBtn">
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Background"      Value="#333"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>
        <Style TargetType="TextBox" x:Key="InputBox">
            <Setter Property="Background"      Value="#2C2C2C"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 活动组名 -->
        <TextBlock Grid.Row="0" Text="活动组名（同一玩法多期共用同一组名）"
                   Style="{StaticResource Label}"/>
        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="GroupCombo"
                      Background="#2C2C2C" Foreground="White"
                      BorderBrush="#444" FontSize="13"
                      IsEditable="True"
                      SelectionChanged="GroupCombo_SelectionChanged">
                <ComboBox.Resources>
                    <!-- 编辑框前景/背景 -->
                    <Style TargetType="TextBox">
                        <Setter Property="Background"     Value="#2C2C2C"/>
                        <Setter Property="Foreground"     Value="White"/>
                        <Setter Property="CaretBrush"     Value="White"/>
                        <Setter Property="SelectionBrush" Value="#1A5C3A"/>
                    </Style>
                    <!-- 下拉列表项 -->
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background"   Value="#2C2C2C"/>
                        <Setter Property="Foreground"   Value="White"/>
                        <Setter Property="Padding"      Value="8,5"/>
                        <Setter Property="FontSize"     Value="13"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A5C3A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1A4A6A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.Resources>
                <ComboBox.Template>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.ColumnSpan="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1" CornerRadius="0"/>
                            <TextBox x:Name="PART_EditableTextBox"
                                     Grid.Column="0"
                                     Background="Transparent"
                                     Foreground="White"
                                     CaretBrush="White"
                                     SelectionBrush="#1A5C3A"
                                     BorderThickness="0"
                                     Padding="6,4"
                                     FontSize="13"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"
                                     Focusable="True"
                                     Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Text, UpdateSourceTrigger=PropertyChanged}"/>
                            <ToggleButton Grid.Column="1"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Foreground="#888"
                                          FontSize="10"
                                          Content="▾"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press"/>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                <Border Background="#2C2C2C" BorderBrush="#555" BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </ComboBox.Template>
            </ComboBox>
            <Button Grid.Column="1" Content="清空" Style="{StaticResource SecBtn}"
                    Margin="6,0,0,0" Click="ClearGroup_Click"/>
        </Grid>

        <!-- 期次名 -->
        <TextBlock Grid.Row="2" Text="期次名称（如：第2期）"
                   Style="{StaticResource Label}"/>
        <TextBox x:Name="InstanceBox" Grid.Row="3"
                 Style="{StaticResource InputBox}"
                 Margin="0,0,0,0"/>

        <!-- 底部按钮 -->
        <Border Grid.Row="5" BorderBrush="#333" BorderThickness="0,1,0,0"
                Margin="0,12,0,0" Padding="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="跳过" Style="{StaticResource SecBtn}"
                        Margin="0,0,8,0" Click="Skip_Click"
                        ToolTip="不命名，直接保存到历史"/>
                <Button Content="取消克隆" Style="{StaticResource SecBtn}"
                        Margin="0,0,8,0" Click="Cancel_Click"/>
                <Button Content="确认" Style="{StaticResource PrimaryBtn}"
                        Click="Confirm_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
