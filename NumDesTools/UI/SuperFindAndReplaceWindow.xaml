<ui:FluentWindow
    x:Class="NumDesTools.UI.SuperFindAndReplaceWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
    x:Name="Root"
    Title="超级查找替换"
    Width="600"
    Height="400"
    MinWidth="400"
    MinHeight="300"
    MaxWidth="1200"
    MaxHeight="800"
    WindowStartupLocation="CenterScreen"
    KeyDown="Window_KeyDown">
    <ui:FluentWindow.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{Binding AccentCol, ElementName=Root}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            Background="{Binding BgInput, ElementName=Root}"
                            BorderBrush="{Binding BorderCol, ElementName=Root}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 编辑器区域 -->
        <Border
            Grid.Row="0"
            BorderBrush="{Binding BorderCol, ElementName=Root}"
            BorderThickness="1"
            CornerRadius="6"
            Margin="0,0,0,10">
            <avalonedit:TextEditor
                x:Name="TextEditor"
                FontFamily="Consolas"
                FontSize="14"
                ShowLineNumbers="True"
                WordWrap="True"
                Background="{Binding BgInput, ElementName=Root}"
                Foreground="{Binding FgMain, ElementName=Root}"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto"/>
        </Border>

        <!-- 操作栏 -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                <TextBlock
                    Text="替换为："
                    VerticalAlignment="Center"
                    Margin="0,0,6,0"
                    Foreground="{Binding FgDim, ElementName=Root}"
                    FontSize="13"/>
                <TextBox
                    x:Name="ReplaceTextBox"
                    Width="260"
                    Height="30"
                    Style="{StaticResource ModernTextBox}"
                    Foreground="{Binding FgMain, ElementName=Root}"
                    CaretBrush="{Binding FgMain, ElementName=Root}"
                    Margin="0,0,8,0"/>
                <Button
                    Width="70" Height="30"
                    Margin="0,0,6,0"
                    Style="{StaticResource ModernButton}"
                    Click="ReplaceAll_Click">
                    <TextBlock Text="替换" Foreground="White" FontSize="13"/>
                </Button>
                <Button
                    Width="70" Height="30"
                    Style="{StaticResource ModernButton}"
                    Click="Reset_Click">
                    <TextBlock Text="重置" Foreground="White" FontSize="13"/>
                </Button>
            </StackPanel>
            <Button
                Grid.Column="1"
                Width="90" Height="30"
                Style="{StaticResource ModernButton}"
                Click="Confirm_Click">
                <TextBlock Text="写入 Excel" Foreground="White" FontSize="13"/>
            </Button>
        </Grid>

        <!-- 状态栏 -->
        <Border
            Grid.Row="2"
            Background="{Binding BgPanel, ElementName=Root}"
            CornerRadius="4"
            Padding="10,5">
            <TextBlock
                x:Name="MatchCountTextBlock"
                Text="匹配项数量：0"
                Foreground="{Binding FgDim, ElementName=Root}"
                FontSize="12"/>
        </Border>
    </Grid>
</ui:FluentWindow>
