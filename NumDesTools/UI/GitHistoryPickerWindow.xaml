<mah:MetroWindow
    x:Class="NumDesTools.UI.GitHistoryPickerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    Title="选择历史版本"
    MinWidth="700" MinHeight="400"
    WindowStartupLocation="CenterScreen"
    KeyDown="Window_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 作者筛选 -->
        <Grid Grid.Row="0" Margin="10,6,10,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="作者：" VerticalAlignment="Center" FontSize="11"
                       Margin="0,0,6,0"
                       Foreground="{DynamicResource MahApps.Brushes.Gray3}"/>
            <ComboBox x:Name="AuthorFilterBox" Grid.Column="1"
                      FontFamily="Consolas" FontSize="11"
                      SelectionChanged="AuthorFilter_Changed"/>
        </Grid>

        <!-- 提交列表 -->
        <ListBox x:Name="CommitList"
                 Grid.Row="1"
                 FontFamily="Consolas" FontSize="11"
                 BorderThickness="0"
                 DisplayMemberPath="Display"
                 Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                 Foreground="{DynamicResource MahApps.Brushes.Text}"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.ScrollUnit="Item"
                 SelectionMode="Single"
                 MouseDoubleClick="CommitList_MouseDoubleClick"
                 KeyDown="CommitList_KeyDown"
                 ScrollViewer.ScrollChanged="CommitList_ScrollChanged">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="6,2"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- 状态栏 -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="2"
                   Padding="10,4"
                   FontSize="11"
                   Foreground="{DynamicResource MahApps.Brushes.Gray5}"
                   Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                   Text="加载中…"/>

        <!-- 底部按钮区 -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray7}"
                BorderThickness="0,1,0,0"
                Padding="10,8">
            <StackPanel x:Name="ButtonPanel" Orientation="Horizontal"/>
        </Border>
    </Grid>
</mah:MetroWindow>
