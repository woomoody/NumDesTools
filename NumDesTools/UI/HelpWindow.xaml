<mah:MetroWindow
    x:Class="NumDesTools.UI.HelpWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    Title="NumDesTools 帮助"
    Width="1100" Height="700"
    WindowState="Maximized"
    WindowStartupLocation="CenterScreen"
    FontFamily="微软雅黑"
    KeyDown="Window_EscClose">

    <mah:MetroWindow.Resources>
        <!-- Group 节点 -->
        <Style TargetType="TreeViewItem" x:Key="GroupItem">
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Text}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="Bd" Background="Transparent" Padding="8,5,6,5">
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton x:Name="Expander"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Focusable="False" Width="14" Height="14"
                                                  Background="Transparent" BorderThickness="0"
                                                  VerticalAlignment="Center" Margin="0,0,4,0">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <TextBlock x:Name="Arrow" Text="▶"
                                                                       Foreground="{DynamicResource MahApps.Brushes.Gray5}"
                                                                       FontSize="9" VerticalAlignment="Center"/>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                    <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ItemsPresenter x:Name="Items" Visibility="Collapsed"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="Items" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger SourceName="Bd" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource MahApps.Brushes.Gray9}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Item 子节点 -->
        <Style TargetType="TreeViewItem" x:Key="LeafItem">
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Gray3}"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="28,5,6,5" Cursor="Hand">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource MahApps.Brushes.Accent4}"/>
                            </Trigger>
                            <Trigger SourceName="Bd" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource MahApps.Brushes.Gray9}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧导航 -->
        <Border Grid.Column="0"
                Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="功能导航"
                           Foreground="{DynamicResource MahApps.Brushes.Gray5}"
                           FontSize="10"
                           Margin="8,8,8,4"/>
                <TreeView x:Name="NavTreeView"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="0,6"
                          SelectedItemChanged="NavTreeView_SelectedItemChanged"
                          VirtualizingPanel.IsVirtualizing="False"/>
            </DockPanel>
        </Border>

        <!-- 可拖拽分隔线 -->
        <GridSplitter Grid.Column="1" Width="4"
                      Background="{DynamicResource MahApps.Brushes.Gray7}"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

        <!-- 右侧 WebBrowser 内容区 -->
        <WebBrowser x:Name="HelpBrowser" Grid.Column="2"/>
    </Grid>
</mah:MetroWindow>
