<Window
    x:Class="NumDesTools.UI.HelpWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="NumDesTools 帮助"
    Width="1100" Height="700"
    WindowState="Maximized"
    WindowStartupLocation="CenterScreen"
    Background="#1E1E1E"
    FontFamily="微软雅黑"
    KeyDown="Window_EscClose">

    <Window.Resources>
        <!-- TreeView 整体背景 -->
        <Style TargetType="TreeView" x:Key="NavTree">
            <Setter Property="Background"       Value="#252525"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="0,6"/>
        </Style>

        <!-- Group 节点（粗体白色16px） -->
        <Style TargetType="TreeViewItem" x:Key="GroupItem">
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontWeight"       Value="Bold"/>
            <Setter Property="FontSize"         Value="16"/>
            <Setter Property="Padding"          Value="6,4"/>
            <Setter Property="IsExpanded"       Value="True"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="Bd" Background="Transparent" Padding="8,5,6,5">
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton x:Name="Expander"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Focusable="False" Width="14" Height="14"
                                                  Background="Transparent" BorderThickness="0"
                                                  Foreground="#888" FontSize="10"
                                                  VerticalAlignment="Center" Margin="0,0,4,0">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <TextBlock x:Name="Arrow" Text="▶" Foreground="#888" FontSize="9" VerticalAlignment="Center"/>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                    <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ItemsPresenter x:Name="Items" Visibility="Collapsed"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="Items" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger SourceName="Bd" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E2E2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Item 子节点（灰色13px可hover变亮，选中高亮#3A3A5A） -->
        <Style TargetType="TreeViewItem" x:Key="LeafItem">
            <Setter Property="Foreground"       Value="#BBBBBB"/>
            <Setter Property="FontWeight"       Value="Normal"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Padding"          Value="6,3"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="28,5,6,5" Cursor="Hand">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A5A"/>
                            </Trigger>
                            <Trigger SourceName="Bd" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E2E3E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧导航 -->
        <Border Grid.Column="0" Background="#252525">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="功能导航"
                           Foreground="#888888"
                           FontSize="10"
                           Margin="8,8,8,4"/>
                <TreeView x:Name="NavTreeView"
                          Style="{StaticResource NavTree}"
                          SelectedItemChanged="NavTreeView_SelectedItemChanged"
                          VirtualizingPanel.IsVirtualizing="False"/>
            </DockPanel>
        </Border>

        <!-- 可拖拽分隔线 -->
        <GridSplitter Grid.Column="1" Width="4" Background="#333" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

        <!-- 右侧 WebBrowser 内容区 -->
        <WebBrowser x:Name="HelpBrowser" Grid.Column="2"/>
    </Grid>
</Window>
