<mah:MetroWindow
    x:Class="NumDesTools.UI.XlsxSlimmerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    Title="格式瘦身诊断"
    Width="760" Height="560" MinWidth="640" MinHeight="420"
    WindowStartupLocation="CenterScreen"
    KeyDown="Window_KeyDown">

    <Grid Margin="14,12,14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="SheetGrid" Grid.Row="0"
                  Margin="0,0,0,10"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  BorderBrush="{DynamicResource MahApps.Brushes.Gray7}"
                  Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                  Foreground="{DynamicResource MahApps.Brushes.Text}"
                  FontSize="12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Sheet" Binding="{Binding Sheet}" Width="*"/>
                <DataGridTextColumn Header="当前范围(行x列)" Binding="{Binding Used}" Width="140"/>
                <DataGridTextColumn Header="真实数据范围(行x列)" Binding="{Binding True}" Width="150"/>
                <DataGridTextColumn Header="冗余行/列" Binding="{Binding Waste}" Width="120"/>
                <DataGridTextColumn Header="批注数" Binding="{Binding Comment}" Width="70"/>
                <DataGridTextColumn Header="条件格式" Binding="{Binding Cf}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="InfoText" Grid.Row="1"
                   Margin="0,0,0,10" TextWrapping="Wrap"
                   Foreground="{DynamicResource MahApps.Brushes.Gray3}" FontSize="12"/>

        <Button x:Name="SlimButton" Grid.Row="2"
                Content="执行瘦身（原地保存）"
                Height="34" IsDefault="True"
                Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                Click="SlimButton_Click"/>
    </Grid>
</mah:MetroWindow>
