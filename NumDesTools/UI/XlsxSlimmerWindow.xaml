<mah:MetroWindow
    x:Class="NumDesTools.UI.XlsxSlimmerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    Title="xlsx 瘦身（全量扫描）"
    Width="720" Height="600" MinWidth="560" MinHeight="420"
    WindowStartupLocation="CenterScreen"
    KeyDown="Window_KeyDown">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 根目录 + 体积过滤 -->
        <Border Grid.Row="0"
                Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray7}"
                BorderThickness="1" CornerRadius="4" Padding="12,10">
            <StackPanel>
                <TextBlock Text="把纯数字被误存成字符串的单元格转回原生数字类型，并清掉空白行列尾部残留格式（判定见 CellValueNormalizer，往返校验保证 .Text 显示不变）。递归扫描指定根目录下所有 xlsx。"
                           TextWrapping="Wrap" FontSize="11"
                           Foreground="{DynamicResource MahApps.Brushes.Gray3}" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="RootBox" Grid.Column="0" Margin="0,0,6,0"/>
                    <Button Grid.Column="1" Content="浏览…" Margin="0,0,6,0" Click="BrowseRoot_Click"/>
                    <Button Grid.Column="2" Content="扫描" Click="Scan_Click"/>
                </Grid>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="只处理 ≥" VerticalAlignment="Center"
                               Foreground="{DynamicResource MahApps.Brushes.Gray3}" FontSize="11"/>
                    <TextBox x:Name="MinSizeBox" Grid.Column="1" Text="5" Margin="6,0"/>
                    <TextBlock Grid.Column="2" Text="MB 的文件（小文件收益微乎其微）" VerticalAlignment="Center"
                               Foreground="{DynamicResource MahApps.Brushes.Gray3}" FontSize="11"/>
                </Grid>
            </StackPanel>
        </Border>

        <Separator Grid.Row="1" Margin="0,8"/>

        <!-- 全选行 + 统计 -->
        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="SelectAllBox" Grid.Column="0" Content="全选 / 取消全选"
                      Checked="SelectAll_Checked" Unchecked="SelectAll_Unchecked"/>
            <TextBlock x:Name="SummaryText" Grid.Column="1"
                       Foreground="{DynamicResource MahApps.Brushes.Gray3}" FontSize="11"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <!-- 结果列表 -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray7}" BorderThickness="1"
                CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ResultPanel" Margin="4"/>
            </ScrollViewer>
        </Border>

        <!-- 底部 -->
        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" Grid.Column="0"
                       Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                       FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="关闭" Margin="0,0,8,0"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"
                        Click="Close_Click"/>
                <Button x:Name="PreviewButton" Content="预览" Margin="0,0,8,0"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"
                        Click="Preview_Click"/>
                <Button x:Name="RunButton" Content="执行瘦身" IsDefault="True"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                        Click="Run_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</mah:MetroWindow>
