<UserControl
    x:Class="NumDesTools.UI.AIAgentPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    Width="560"
    Background="#1c1c1c">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  顶部：模型 + 最大步骤  -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="80" />
            </Grid.ColumnDefinitions>
            <ComboBox
                x:Name="ModelComboBox"
                Grid.Column="0"
                SelectionChanged="ModelComboBox_SelectionChanged"
                Height="26"
                Margin="0,0,6,0"
                Background="#2d2d30"
                Foreground="#e0e0e0"
                BorderBrush="#555">
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#2d2d30" />
                        <Setter Property="Foreground" Value="#e0e0e0" />
                        <Setter Property="Padding" Value="8,4" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#094771" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#094771" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.ItemContainerStyle>
                <ComboBox.Template>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                Foreground="{TemplateBinding Foreground}"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                Padding="8,0,4,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="20" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter
                                        Grid.Column="0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding SelectionBoxItem}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="#aaa"
                                        Text="▾" />
                                </Grid>
                            </ToggleButton>
                            <Popup
                                AllowsTransparency="True"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom"
                                PopupAnimation="Slide">
                                <Border
                                    MaxHeight="300"
                                    Background="#2d2d30"
                                    BorderBrush="#555"
                                    BorderThickness="1">
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </ComboBox.Template>
            </ComboBox>
            <TextBlock
                Grid.Column="1"
                Margin="0,0,4,0"
                VerticalAlignment="Center"
                Foreground="#888"
                FontSize="11"
                Text="步骤上限：" />
            <mah:NumericUpDown
                x:Name="MaxStepsInput"
                Grid.Column="2"
                Height="26"
                Maximum="200"
                Minimum="1"
                Value="100"
                Background="#2d2d30"
                Foreground="#e0e0e0"
                BorderBrush="#555">
                <mah:NumericUpDown.Resources>
                    <Style TargetType="RepeatButton">
                        <Setter Property="Background" Value="#3e3e42" />
                        <Setter Property="Foreground" Value="#e0e0e0" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#094771" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0e5a8a" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </mah:NumericUpDown.Resources>
            </mah:NumericUpDown>
        </Grid>

        <!--  会话管理：历史选择 + 重命名 + 删除 + 导入 + 压缩 + 新对话  -->
        <Grid Grid.Row="1" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox
                x:Name="SessionComboBox"
                Grid.Column="0"
                Height="26"
                Margin="0,0,6,0"
                Background="#2d2d30"
                Foreground="#e0e0e0"
                BorderBrush="#555"
                SelectionChanged="SessionComboBox_SelectionChanged">
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#2d2d30" />
                        <Setter Property="Foreground" Value="#e0e0e0" />
                        <Setter Property="Padding" Value="6,3" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#094771" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#094771" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.ItemContainerStyle>
                <ComboBox.Template>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                Foreground="{TemplateBinding Foreground}"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                Padding="8,0,4,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="20" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter
                                        Grid.Column="0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding SelectionBoxItem}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="#aaa"
                                        Text="▾" />
                                </Grid>
                            </ToggleButton>
                            <Popup
                                AllowsTransparency="True"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom"
                                PopupAnimation="Slide">
                                <Border
                                    MaxHeight="300"
                                    Background="#2d2d30"
                                    BorderBrush="#555"
                                    BorderThickness="1">
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </ComboBox.Template>
            </ComboBox>
            <Button
                x:Name="RenameSessionButton"
                Grid.Column="1"
                Width="28"
                Height="26"
                Margin="0,0,4,0"
                Background="#3e3e42"
                Foreground="#ccc"
                Content="✏"
                ToolTip="重命名会话"
                Click="RenameSessionButton_Click" />
            <Button
                x:Name="DeleteSessionButton"
                Grid.Column="2"
                Width="46"
                Height="26"
                Margin="0,0,4,0"
                Background="#5a2727"
                Foreground="White"
                Content="删除"
                Click="DeleteSessionButton_Click" />
            <Button
                x:Name="ImportButton"
                Grid.Column="3"
                Width="46"
                Height="26"
                Margin="0,0,4,0"
                Background="#3e3e42"
                Foreground="#ccc"
                Content="导入"
                Click="ImportButton_Click" />
            <Button
                x:Name="CompressButton"
                Grid.Column="4"
                Width="72"
                Height="26"
                Margin="0,0,4,0"
                Background="#3e3e42"
                Foreground="#ccc"
                Content="压缩上下文"
                Click="CompressButton_Click" />
            <Button
                x:Name="NewChatButton"
                Grid.Column="5"
                Width="70"
                Height="26"
                Background="#2d5a27"
                Foreground="White"
                Content="＋ 新对话"
                Click="NewChatButton_Click" />
        </Grid>

        <!--  自定义指令  -->
        <Expander
            Grid.Row="2"
            Margin="0,0,0,6"
            Header="自定义指令（每次对话自动带入）"
            Foreground="#888"
            BorderBrush="#333">
            <TextBox
                x:Name="CustomInstructionInput"
                MinHeight="40"
                MaxHeight="80"
                Padding="6,5"
                AcceptsReturn="True"
                Background="#2d2d30"
                BorderBrush="#444"
                BorderThickness="1"
                FontSize="12"
                Foreground="#ccc"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto"
                mah:TextBoxHelper.Watermark="例：翻译结果统一放到C列；输出中文；不要修改第一行…" />
        </Expander>

        <!--  对话区（上）+ 步骤面板（下，可折叠）  -->
        <Grid Grid.Row="3" Margin="0,0,0,6">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="140" />
            </Grid.RowDefinitions>

            <!--  对话输出  -->
            <Border
                Grid.Row="0"
                BorderBrush="#333"
                BorderThickness="1"
                CornerRadius="4">
                <WebBrowser x:Name="ChatOutput" />
            </Border>

            <GridSplitter
                Grid.Row="1"
                Height="6"
                HorizontalAlignment="Stretch"
                Background="Transparent"
                Cursor="SizeNS" />

            <!--  步骤面板  -->
            <Border
                Grid.Row="2"
                BorderBrush="#333"
                BorderThickness="1"
                CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        Padding="6,4"
                        Background="#2d2d30"
                        FontSize="11"
                        FontWeight="Bold"
                        Foreground="#888"
                        Text="执行步骤" />
                    <ScrollViewer
                        x:Name="StepsScroll"
                        Grid.Row="1"
                        VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="StepsList" Margin="6,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Margin="0,1"
                                        FontSize="11"
                                        Foreground="#aaa"
                                        Text="{Binding}"
                                        TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!--  任务输入  -->
        <Grid Grid.Row="4" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border
                Grid.Column="0"
                Margin="0,0,6,0"
                BorderBrush="#444"
                BorderThickness="1"
                CornerRadius="3">
                <TextBox
                    x:Name="TaskInput"
                    MinHeight="36"
                    MaxHeight="200"
                    Padding="6,5"
                    AcceptsReturn="True"
                    Background="#1c1c1c"
                    BorderThickness="0"
                    FontSize="10pt"
                    Foreground="#e0e0e0"
                    PreviewKeyDown="TaskInput_PreviewKeyDown"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Hidden"
                    HorizontalScrollBarVisibility="Disabled"
                    mah:TextBoxHelper.Watermark="描述任务，Enter 发送，Shift+Enter 换行…" />
            </Border>
            <Button
                x:Name="StopButton"
                Grid.Column="1"
                Width="52"
                Height="32"
                Margin="0,0,4,0"
                Background="#3e3e42"
                Click="StopButton_Click"
                Content="停止"
                Foreground="#aaa"
                IsEnabled="False" />
            <Button
                x:Name="RunButton"
                Grid.Column="2"
                Width="64"
                Height="32"
                Background="#0078d4"
                Click="RunButton_Click"
                Content="执行"
                Foreground="White">
                <Button.Style>
                    <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!--  状态栏  -->
        <TextBlock
            x:Name="StatusText"
            Grid.Row="5"
            FontSize="10"
            Foreground="#555"
            Text="就绪" />
    </Grid>
</UserControl>
