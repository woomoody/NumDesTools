<mah:MetroWindow
    x:Class="NumDesTools.UI.ActivityBackupSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    Title="大文件备份设置"
    Width="620" Height="260" MinWidth="520" MinHeight="230"
    WindowStartupLocation="CenterScreen"
    KeyDown="Window_KeyDown">

    <Grid Margin="14,12,14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="70"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="备份根目录" VerticalAlignment="Center"
                   Foreground="{DynamicResource MahApps.Brushes.Gray3}"/>
        <TextBox x:Name="BackupRootBox" Grid.Row="0" Grid.Column="1" Margin="0,4,6,4"/>
        <Button Grid.Row="0" Grid.Column="2" Content="浏览…" Margin="0,4,0,4" Click="BrowseBackupRoot_Click"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="正式表根目录" VerticalAlignment="Center"
                   Foreground="{DynamicResource MahApps.Brushes.Gray3}"/>
        <TextBox x:Name="LiveRootBox" Grid.Row="1" Grid.Column="1" Margin="0,4,6,4"/>
        <Button Grid.Row="1" Grid.Column="2" Content="浏览…" Margin="0,4,0,4" Click="BrowseLiveRoot_Click"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,10,0,0"
                   TextWrapping="Wrap" VerticalAlignment="Top"
                   Foreground="{DynamicResource MahApps.Brushes.Gray3}" FontSize="11"
                   Text="删除只动正式表（Type.xlsx/Icon.xlsx/Item.xlsx，在正式表根目录下递归找）。还原会在备份根目录下按「表名_backup_日期」找最新一份备份，把对应 id 区间的数据同步回正式表。"/>

        <Button x:Name="SaveButton" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                Content="保存" Height="34" IsDefault="True"
                Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                Click="SaveRoots_Click"/>
    </Grid>
</mah:MetroWindow>
