<Window
    x:Class="NumDesTools.UI.GitExportSelectWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Git 变更导出 — 选择文件"
    Width="680" Height="580" MinWidth="500" MinHeight="400"
    WindowStartupLocation="CenterScreen"
    Background="#1E1E1E" Foreground="White"
    KeyDown="Window_EscClose">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionBtn">
            <Setter Property="Padding"         Value="14,6"/>
            <Setter Property="Margin"          Value="4,0"/>
            <Setter Property="Background"      Value="#333"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Padding"         Value="14,6"/>
            <Setter Property="Background"      Value="#1A5C3A"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Margin"          Value="0,0,8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Margin"          Value="0,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0: 模式选择 -->
            <RowDefinition Height="Auto"/>   <!-- 1: 分隔 -->
            <RowDefinition Height="Auto"/>   <!-- 2: 全选/取消 + 统计 -->
            <RowDefinition Height="*"/>      <!-- 3: 文件列表 -->
            <RowDefinition Height="Auto"/>   <!-- 4: 底部按钮 -->
        </Grid.RowDefinitions>

        <!-- 模式选择区 -->
        <Border Grid.Row="0" Background="#252525" CornerRadius="4" Padding="12,8">
            <StackPanel>
                <TextBlock Text="导出范围" Foreground="#888" FontSize="11" Margin="0,0,0,6"/>
                <RadioButton x:Name="ModeGitStaged" Content="Git 变更 + 暂存区"
                             GroupName="ExportMode" IsChecked="True"
                             Checked="Mode_Changed"/>
                <RadioButton x:Name="ModeWithHistory" Content="Git 变更 + 暂存区 + 近期提交"
                             GroupName="ExportMode" Margin="0,4,0,0"
                             Checked="Mode_Changed"/>
                <StackPanel Orientation="Horizontal" Margin="20,4,0,2"
                            x:Name="HistoryAuthorRow" IsEnabled="False">
                    <TextBlock Text="作者：" Foreground="#666" FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock x:Name="AuthorText" Foreground="#88CCFF" FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock Text="（当前 git user.name）" Foreground="#444" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="20,2,0,0"
                            x:Name="HistoryPanel" IsEnabled="False">
                    <TextBlock Text="最近" Foreground="#AAAAAA" FontSize="11" VerticalAlignment="Center"/>
                    <Border Background="#333" CornerRadius="3" Margin="6,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="-" Width="22" Height="22"
                                    Style="{StaticResource ActionBtn}" Padding="0"
                                    Click="DecCommitCount_Click"/>
                            <TextBlock x:Name="CommitCountText" Text="3"
                                       Foreground="White" FontSize="12" Width="28"
                                       TextAlignment="Center" VerticalAlignment="Center"/>
                            <Button Content="+" Width="22" Height="22"
                                    Style="{StaticResource ActionBtn}" Padding="0"
                                    Click="IncCommitCount_Click"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="次我的提交" Foreground="#AAAAAA" FontSize="11" VerticalAlignment="Center"/>
                    <Button x:Name="RefreshBtn" Content="刷新" Margin="12,0,0,0"
                            Style="{StaticResource ActionBtn}" Padding="8,2"
                            Click="Refresh_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Separator Grid.Row="1" Background="#333" Margin="0,8"/>

        <!-- 全选行 + 文件数统计 -->
        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <CheckBox x:Name="SelectAllBox" Content="全选 / 取消全选"
                          Checked="SelectAll_Checked" Unchecked="SelectAll_Unchecked"/>
            </StackPanel>
            <TextBlock x:Name="FileCountText" Grid.Column="1"
                       Foreground="#888" FontSize="11"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <!-- 文件列表 -->
        <Border Grid.Row="3" Background="#141414" CornerRadius="4"
                BorderBrush="#333" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="FileListPanel" Margin="4"/>
            </ScrollViewer>
        </Border>

        <!-- 底部按钮 -->
        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" Grid.Column="0"
                       Foreground="#666" FontSize="11" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="取消" Style="{StaticResource ActionBtn}" Click="Cancel_Click"/>
                <Button x:Name="ExportBtn" Content="导出选中文件"
                        Style="{StaticResource PrimaryBtn}" Click="Export_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
