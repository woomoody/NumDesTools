<mah:MetroWindow
    x:Class="NumDesTools.UI.GitExportSelectWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    Title="Git 变更导出 — 选择文件"
    Width="680" Height="580" MinWidth="500" MinHeight="400"
    WindowStartupLocation="CenterScreen"
    KeyDown="Window_EscClose">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 模式选择区 -->
        <Border Grid.Row="0"
                Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray7}"
                BorderThickness="1"
                CornerRadius="4" Padding="12,10">
            <StackPanel>
                <TextBlock Text="导出范围"
                           Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                           FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <RadioButton x:Name="ModeGitStaged" Content="Git 变更 + 暂存区"
                             GroupName="ExportMode" IsChecked="True" Checked="Mode_Changed"/>

                <RadioButton x:Name="ModeWithHistory" Content="Git 变更 + 暂存区 + 近期提交"
                             GroupName="ExportMode" Margin="0,6,0,0" Checked="Mode_Changed"/>
                <StackPanel x:Name="HistoryAuthorRow" IsEnabled="False" Margin="22,3,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="作者："
                                   Foreground="{DynamicResource MahApps.Brushes.Gray5}"
                                   FontSize="10" VerticalAlignment="Center"/>
                        <TextBlock x:Name="AuthorText"
                                   Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                   FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel x:Name="HistoryPanel" IsEnabled="False" Orientation="Horizontal"
                            Margin="22,4,0,0">
                    <TextBlock Text="最近"
                               Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                               FontSize="11" VerticalAlignment="Center"/>
                    <Border BorderBrush="{DynamicResource MahApps.Brushes.Gray7}"
                            BorderThickness="1" CornerRadius="3" Margin="6,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="−" Width="22" Height="22" Padding="0"
                                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                                    Click="DecCommitCount_Click"/>
                            <TextBlock x:Name="CommitCountText" Text="3"
                                       Foreground="{DynamicResource MahApps.Brushes.Text}"
                                       FontSize="12" Width="28"
                                       TextAlignment="Center" VerticalAlignment="Center"/>
                            <Button Content="+" Width="22" Height="22" Padding="0"
                                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                                    Click="IncCommitCount_Click"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="次我的提交"
                               Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                               FontSize="11" VerticalAlignment="Center"/>
                    <Button Content="刷新" Margin="10,0,0,0" Padding="8,2"
                            Style="{DynamicResource MahApps.Styles.Button.Square}"
                            Click="Refresh_Click"/>
                </StackPanel>

                <!-- 指定提交模式 -->
                <RadioButton x:Name="ModeSpecificCommit" Content="指定某次提交"
                             GroupName="ExportMode" Margin="0,6,0,0" Checked="Mode_Changed"/>
                <StackPanel x:Name="CommitPickPanel" IsEnabled="False" Margin="22,6,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="选择提交："
                                   Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Content="加载列表" Padding="8,2"
                                Style="{DynamicResource MahApps.Styles.Button.Square}"
                                Click="LoadCommitList_Click"/>
                    </StackPanel>
                    <ComboBox x:Name="CommitCombo"
                              MaxWidth="560" HorizontalAlignment="Left"
                              FontFamily="Consolas" FontSize="11"
                              SelectionChanged="CommitCombo_SelectionChanged"
                              DisplayMemberPath="Display"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Separator Grid.Row="1" Margin="0,8"/>

        <!-- 全选行 + 文件数统计 -->
        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="SelectAllBox" Grid.Column="0" Content="全选 / 取消全选"
                      Checked="SelectAll_Checked" Unchecked="SelectAll_Unchecked"/>
            <TextBlock x:Name="FileCountText" Grid.Column="1"
                       Foreground="{DynamicResource MahApps.Brushes.Gray3}" FontSize="11"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <!-- 文件列表 -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray7}" BorderThickness="1"
                CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="FileListPanel" Margin="4"/>
            </ScrollViewer>
        </Border>

        <!-- 底部 -->
        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" Grid.Column="0"
                       Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                       FontSize="11" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="取消" Margin="0,0,8,0"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"
                        Click="Cancel_Click"/>
                <Button Content="导出选中文件"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                        Click="Export_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</mah:MetroWindow>
