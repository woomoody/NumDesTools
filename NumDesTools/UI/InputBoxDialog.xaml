<Window
    x:Class="NumDesTools.UI.InputBoxDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    SizeToContent="WidthAndHeight"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    KeyDown="Window_KeyDown">
    <StackPanel Margin="12">
        <TextBlock x:Name="PromptText" TextWrapping="Wrap"/>
        <ui:TextBox x:Name="InputBox" MinWidth="320" Margin="0,8,0,0"/>
        <ui:Button HorizontalAlignment="Right" IsDefault="True"
                   Margin="0,8,0,0" Click="OkButton_Click" Content="确定"/>
    </StackPanel>
</Window>
