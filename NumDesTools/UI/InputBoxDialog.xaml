<mah:MetroWindow
    x:Class="NumDesTools.UI.InputBoxDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    SizeToContent="WidthAndHeight"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    KeyDown="Window_KeyDown">
    <StackPanel Margin="16">
        <TextBlock x:Name="PromptText" TextWrapping="Wrap" FontSize="13"
                   Foreground="{DynamicResource MahApps.Brushes.Text}"/>
        <TextBox x:Name="InputBox" MinWidth="320" Margin="0,10,0,0"/>
        <Button HorizontalAlignment="Right" IsDefault="True" Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                Margin="0,10,0,0" Click="OkButton_Click" Content="确定"/>
    </StackPanel>
</mah:MetroWindow>
