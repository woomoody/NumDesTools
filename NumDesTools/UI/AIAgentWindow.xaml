<mah:MetroWindow
    x:Class="NumDesTools.UI.AIAgentWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    Title="AI Agent"
    Width="900"
    Height="700"
    MinWidth="640"
    MinHeight="500"
    WindowStartupLocation="CenterScreen"
    KeyDown="Window_KeyDown">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  顶部：模型选择 + 最大步骤  -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Margin="0,0,6,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                Text="模型：" />
            <ComboBox
                x:Name="ModelComboBox"
                Grid.Column="1"
                Height="28"
                Margin="0,0,12,0" />
            <TextBlock
                Grid.Column="2"
                Margin="0,0,6,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                Text="最大步骤：" />
            <mah:NumericUpDown
                x:Name="MaxStepsInput"
                Grid.Column="3"
                Height="28"
                Margin="0,0,0,0"
                Maximum="20"
                Minimum="1"
                Value="10" />
        </Grid>

        <!--  主区域：左侧步骤 + 右侧对话  -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  步骤面板  -->
            <Border
                Grid.Column="0"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray7}"
                BorderThickness="1"
                CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        Padding="8,5"
                        Background="{DynamicResource MahApps.Brushes.Gray10}"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                        Text="执行步骤" />
                    <ScrollViewer
                        x:Name="StepsScroll"
                        Grid.Row="1"
                        VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="StepsList" Margin="6,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Margin="0,2"
                                        FontSize="11"
                                        Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                        Text="{Binding}"
                                        TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter
                Grid.Column="1"
                Width="6"
                HorizontalAlignment="Stretch"
                Background="Transparent" />

            <!--  对话区  -->
            <Border
                Grid.Column="2"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray7}"
                BorderThickness="1"
                CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        Padding="8,5"
                        Background="{DynamicResource MahApps.Brushes.Gray10}"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                        Text="对话 / 结果" />
                    <WebBrowser x:Name="ChatOutput" Grid.Row="1" />
                </Grid>
            </Border>
        </Grid>

        <!--  任务输入区  -->
        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border
                Grid.Column="0"
                Margin="0,0,6,0"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray7}"
                BorderThickness="1"
                CornerRadius="3">
                <TextBox
                    x:Name="TaskInput"
                    MinHeight="60"
                    MaxHeight="120"
                    Padding="8,6"
                    AcceptsReturn="True"
                    Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                    BorderThickness="0"
                    FontSize="13"
                    Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                    PreviewKeyDown="TaskInput_PreviewKeyDown"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto"
                    mah:TextBoxHelper.Watermark="描述任务，Enter 发送，Shift+Enter 换行…" />
            </Border>
            <Button
                x:Name="StopButton"
                Grid.Column="1"
                Width="64"
                Height="34"
                Margin="0,0,6,0"
                Style="{DynamicResource MahApps.Styles.Button.Square}"
                Click="StopButton_Click"
                Content="停止"
                IsEnabled="False" />
            <Button
                x:Name="RunButton"
                Grid.Column="2"
                Width="80"
                Height="34"
                Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                Click="RunButton_Click"
                Content="执行" />
        </Grid>

        <!--  状态栏  -->
        <TextBlock
            x:Name="StatusText"
            Grid.Row="3"
            FontSize="11"
            Foreground="{DynamicResource MahApps.Brushes.Gray5}"
            Text="就绪  |  可用工具：read_selection · write_range · run_formula · list_udfs · read_sheet" />
    </Grid>
</mah:MetroWindow>
