<Window
    x:Class="NumDesTools.UI.CloneActivityWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="活动数据克隆"
    Width="820" Height="580" MinWidth="640" MinHeight="420"
    WindowStartupLocation="CenterScreen"
    Background="#1E1E1E"
    FontFamily="微软雅黑"
    KeyDown="Window_EscClose">

    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Padding"         Value="16,6"/>
            <Setter Property="Background"      Value="#1A5C3A"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="13"/>
        </Style>
        <Style TargetType="Button" x:Key="SecBtn">
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Background"      Value="#333"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>
        <Style TargetType="Button" x:Key="SmallBtn">
            <Setter Property="Padding"         Value="6,2"/>
            <Setter Property="Background"      Value="#2A2A2A"/>
            <Setter Property="Foreground"      Value="#AAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="11"/>
        </Style>
        <Style TargetType="TextBox" x:Key="CellBox">
            <Setter Property="Background"      Value="#2C2C2C"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="4,2"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="ColHead">
            <Setter Property="Foreground"   Value="#888"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Padding"      Value="6,3"/>
        </Style>
        <Style TargetType="CheckBox" x:Key="ToggleCheck">
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Bd"
                                Background="#2A2A2A" BorderBrush="#555" BorderThickness="1"
                                CornerRadius="3" Padding="8,4" Cursor="Hand">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"   Value="#1A5C3A"/>
                                <Setter TargetName="Bd" Property="BorderBrush"  Value="#2A8C5A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Bd" Property="Background"   Value="#3A1A1A"/>
                                <Setter TargetName="Bd" Property="BorderBrush"  Value="#7A3A3A"/>
                                <Setter Property="Foreground" Value="#CC8888"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"  Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding"      Value="8,4"/>
            <Setter Property="Foreground"   Value="#CCC"/>
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1A4A6A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A3A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ 左侧主区域 ═══ -->
        <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 列头 -->
            <Grid Grid.Row="0" Background="#252525" Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="源 ID（克隆对象）" Style="{StaticResource ColHead}"/>
                <TextBlock Grid.Column="1" Text="目标 ID（替换成什么）" Style="{StaticResource ColHead}"/>
                <TextBlock Grid.Column="2" Text="备注" Style="{StaticResource ColHead}"/>
                <TextBlock Grid.Column="3" Text="绑定表" Style="{StaticResource ColHead}" ToolTip="手动映射绑定到指定表（空=全局）"/>
                <TextBlock Grid.Column="4" Text="" Style="{StaticResource ColHead}"/>
            </Grid>

            <!-- ID 对照表格 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="IdRowList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <Grid.Background>
                                    <SolidColorBrush Color="{Binding RowBg}"/>
                                </Grid.Background>
                                <TextBox Grid.Column="0" Text="{Binding SourceId, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource CellBox}" Margin="0,0,2,0"
                                         ToolTip="{Binding SourceId}"/>
                                <TextBox Grid.Column="1" Text="{Binding TargetId, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource CellBox}" Margin="0,0,2,0"
                                         ToolTip="{Binding TargetId}"/>
                                <TextBox Grid.Column="2" Text="{Binding Remark, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource CellBox}" Margin="0,0,2,0"
                                         Foreground="#BBB"/>
                                <TextBox Grid.Column="3" Text="{Binding BoundTable, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource CellBox}" Margin="0,0,2,0"
                                         Foreground="#888" FontSize="10"
                                         ToolTip="{Binding BoundTable}"/>
                                <Button Grid.Column="4" Content="×" Style="{StaticResource SmallBtn}"
                                        Tag="{Binding}" Click="RemoveRow_Click"
                                        Foreground="#C04040" FontSize="14" FontWeight="Bold"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 添加行 / 源ID±  / 目标ID± 按钮行 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,6">
                <Button Content="＋ 添加一行" Style="{StaticResource SecBtn}"
                        Margin="0,0,10,0" Click="AddRow_Click"/>
                <TextBlock Text="源ID" Foreground="#888" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                <Button Content="＋" Style="{StaticResource SecBtn}"
                        Margin="0,0,2,0" Click="SrcIncrement_Click"
                        ToolTip="源ID 按步长+1组"/>
                <Button Content="－" Style="{StaticResource SecBtn}"
                        Margin="0,0,12,0" Click="SrcDecrement_Click"
                        ToolTip="源ID 按步长-1组（下限1）"/>
                <TextBlock Text="目标ID" Foreground="#888" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                <Button Content="＋" Style="{StaticResource SecBtn}"
                        Margin="0,0,2,0" Click="DstIncrement_Click"
                        ToolTip="目标ID 按步长+1组"/>
                <Button Content="－" Style="{StaticResource SecBtn}"
                        Click="DstDecrement_Click"
                        ToolTip="目标ID 按步长-1组（下限1）"/>
            </StackPanel>

            <!-- 活动备注：源关键字 → 目标替换文本 -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="备注关键字（源）：" Foreground="#888" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="RemarkBox" Grid.Column="1"
                         Style="{StaticResource CellBox}" Margin="0,0,6,0"
                         ToolTip="用于在 ActivityClientData 中辅助匹配含该关键字的行（可留空）"/>
                <TextBlock Grid.Column="2" Text="→ 替换为：" Foreground="#888" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="RemarkDstBox" Grid.Column="3"
                         Style="{StaticResource CellBox}"
                         ToolTip="克隆行的 #备注 列中，将源关键字替换为此文本（留空=不替换）"/>
            </Grid>

            <!-- 特殊字段决策（历史可回填，用户可修改） -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,8,0,2">
                <CheckBox x:Name="ReplaceArtCheck"
                          Content="替换美术资源字段"
                          Style="{StaticResource ToggleCheck}"
                          IsChecked="True"
                          ToolTip="绿色=替换；红色=保留原值"
                          Margin="0,0,10,0"/>
                <CheckBox x:Name="ReplaceSubCheck"
                          Content="替换子表ID字段"
                          Style="{StaticResource ToggleCheck}"
                          IsChecked="False"
                          ToolTip="绿色=替换；红色=保留原值"
                          Margin="0,0,10,0"/>
                <CheckBox x:Name="IncrementRemarkCheck"
                          Content="自增备注序号（第N期）"
                          Style="{StaticResource ToggleCheck}"
                          IsChecked="True"
                          ToolTip="绿色=自动将备注中的「第N期」递增；红色=保留原备注文本"/>
            </StackPanel>

            <!-- 疑似表决策列表（有疑似表时才显示） -->
            <StackPanel x:Name="SuspectPanel" Grid.Row="5" Margin="0,4,0,0"
                        Visibility="Collapsed">
                <TextBlock Text="疑似关联表（可取消勾选以跳过）" Foreground="#888"
                           FontSize="11" Margin="0,0,0,3"/>
                <ItemsControl x:Name="SuspectList" MaxHeight="90">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding TableName}"
                                      IsChecked="{Binding Include, Mode=TwoWay}"
                                      Foreground="#BBB" FontSize="11"
                                      Margin="0,1"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <!-- ═══ 右侧历史区域 ═══ -->
        <Grid Grid.Row="0" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="历史记录" Foreground="#888"
                       FontSize="11" Margin="0,0,0,4"/>

            <ListBox x:Name="HistoryList" Grid.Row="1"
                     Background="#252525" BorderBrush="#333" BorderThickness="1"
                     FontSize="11" SelectionChanged="HistoryList_SelectionChanged"
                     KeyDown="HistoryList_KeyDown"
                     MouseDoubleClick="HistoryList_MouseDoubleClick">
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="GroupItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GroupItem">
                                            <StackPanel>
                                                <!-- 组头：点击切换折叠 -->
                                                <ToggleButton x:Name="GroupToggle"
                                                              IsChecked="True"
                                                              Cursor="Hand"
                                                              Background="#1A3A2A"
                                                              BorderThickness="0"
                                                              Padding="6,4"
                                                              Margin="0,2,0,0"
                                                              HorizontalContentAlignment="Stretch">
                                                    <ToggleButton.Template>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock x:Name="Arrow"
                                                                               Grid.Column="0"
                                                                               Text="▾"
                                                                               Foreground="#6EC97E"
                                                                               FontSize="10"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,5,0"/>
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding Name}"
                                                                               Foreground="#6EC97E"
                                                                               FontSize="11"
                                                                               FontWeight="Bold"
                                                                               VerticalAlignment="Center"/>
                                                                </Grid>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="False">
                                                                    <Setter TargetName="Arrow" Property="Text" Value="▸"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#22503A"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </ToggleButton.Template>
                                                </ToggleButton>
                                                <!-- 子项列表：绑定到 ToggleButton.IsChecked -->
                                                <ItemsPresenter x:Name="ItemsHost"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger SourceName="GroupToggle" Property="IsChecked" Value="False">
                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ListBox.GroupStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Label}" TextWrapping="Wrap"
                                   ToolTip="{Binding Tooltip}" Padding="8,0,0,0"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                <Button Content="应用选中" Style="{StaticResource SecBtn}"
                        Click="ApplyHistory_Click" Margin="0,0,4,0"/>
                <Button Content="删除" Style="{StaticResource SmallBtn}"
                        Click="DeleteHistory_Click" Margin="0,0,4,0"/>
                <Button Content="重置屏蔽" Style="{StaticResource SmallBtn}"
                        Click="ResetBlockedAlien_Click"
                        ToolTip="清空选中条目所属活动组的所有异构ID屏蔽记录"/>
            </StackPanel>
        </Grid>

        <!-- ═══ 底部按钮区 ═══ -->
        <Border Grid.Row="1" Grid.ColumnSpan="2"
                BorderBrush="#333" BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Foreground="#666" FontSize="11"
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BlockAlienBtn"
                            Content="🚫 屏蔽此表异构映射"
                            Style="{StaticResource SecBtn}"
                            Visibility="Collapsed"
                            Margin="0,0,8,0" Click="BlockAlien_Click"
                            ToolTip="本方案以后不再对此表弹出异构ID映射对话框"/>
                    <Button Content="取消" Style="{StaticResource SecBtn}"
                            Margin="0,0,8,0" Click="Cancel_Click"/>
                    <Button Content="▶ 开始克隆" Style="{StaticResource PrimaryBtn}"
                            Click="Run_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
