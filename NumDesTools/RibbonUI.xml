<?xml version="1.0" encoding="utf-8"?>

<customUI xmlns='http://schemas.microsoft.com/office/2009/07/customui' loadImage='LoadImage' onLoad='OnLoad'>
        <ribbon startFromScratch='false'>
                <tabs>
                        <tab id='MainTab' label='NumDesTools' insertBeforeMso='TabHome'>
                                <!-- ══ 格式检查 ══ 常用开关大按钮 + 检查类归入下拉 -->
                                <group id='Group2' label='格式检查'>
                                        <button id='SheetMenu' size='large' getLabel='GetLableText' image='nd_表格目录' onAction='OnButtonClick' screentip='点击创建表格目录，再次点击关闭! 报错请删除！配置路径：\Documents\NumDesGlobalKey.json' tag='表格目录开关' />
                                        <button id='CellHiLight' size='large' getLabel='GetLableText' image='nd_高亮单元格' onAction='OnButtonClick' screentip='点击高亮显示一定范围内同值内容，再次点击关闭! 报错请删除！配置路径：\Documents\NumDesGlobalKey.json' tag='高亮单元格开关' />
                                        <button id='CheckSheetValue' size='large' getLabel='GetLableText' image='nd_数据自检' onAction='OnButtonClick' screentip='点击启动表格关闭时数据自检，再次点击关闭! 报错请删除！配置路径：\Documents\NumDesGlobalKey.json' tag='数据自检开关' />
                                        <separator id='Sep1' />
                                        <menu id='CheckMenu' label='检查工具&#13;' image='nd_检查工具' size='large'>
                                                <button id='Button8' label='公式检查' imageMso='FormulaEvaluate' onAction='OnButtonClick' screentip='点击检查当前工作簿所有sheet中的公式，看是否有错误的连接，推荐合完表后进行检查' tag='公式检查开关' />
                                                <button id='CheckHiddenCellVsto' label='检查隐藏(当前)' imageMso='FileDocumentInspect' onAction='OnButtonClick' screentip='点击检查当前变动Excel是否有隐藏单元格，VSTO方式需要打开Excel，较慢' tag='检查隐藏' />
                                                <button id='CheckHiddenCellVstoAll' label='检查隐藏(全局)' imageMso='ErrorChecking' onAction='OnButtonClick' screentip='点击检查全量Excel是否有隐藏单元格，VSTO方式需要打开Excel，较慢' tag='检查隐藏（全局）' />
                                                <button id='CheckExcelKeyAndValueFormat' label='检查表格式' imageMso='SpellingAndGrammar' onAction='OnButtonClick' screentip='点击检查全量Excel是否有重复Key，单元格格式是否合法' tag='检查格式' />
                                                <button id='PowerQueryLinksUpdate' label='更新表格路径' imageMso='DataRefreshAll' onAction='OnButtonClick' screentip='更新PowerQuery表连接路径' tag='更新表格路径' />
                                        </menu>
                                        <menu id='LuaExportMenu' label='导出Lua&#13;' image='nd_导出Lua菜单' size='large'>
                                                <button id='OutPutExcelDataToLua' label='Lua表格(当前)' imageMso='FileSave' onAction='OnButtonClick' screentip='将当前表格数据导出为Lua' tag='导出Lua数据' />
                                                <button id='OutPutExcelDataToLuaAll' label='Lua表格(全量)' imageMso='ExportExcel' onAction='OnButtonClick' screentip='导出Git变更+暂存区文件，可选追加近期提交，先弹文件确认列表' tag='导出Lua数据All' />
                                        </menu>
                                </group>
                                <!-- ══ 自动填表 ══ -->
                                <group id='Group7' label='自动填表'>
                                        <menu id='AutoInsertExcelDataMenu' label='自动数据&#13;' image='nd_自动数据菜单' size='large'>
                                                <button id='AutoInsertExcelData' label='自动数据LTE' imageMso='ConnectedToolSyncMenu' onAction='OnButtonClick' screentip='根据模板数据覆写N个类似数据到表格：EPPlusI' tag='自动数据LTE' />
                                                <button id='AutoInsertExcelDataThread' label='自动数据LTE(多线程)' imageMso='ConnectionPoints' onAction='OnButtonClick' screentip='根据模板数据覆写N个类似数据到表格：EPPlusI，多线程更快速' tag='自动数据LTE(多线程)' />
                                                <button id='AutoInsertExcelDataNew' label='自动数据LTE（New）' imageMso='ConnectedToolSyncMenu' onAction='OnButtonClick' screentip='根据模板数据覆写N个类似数据到表格：EPPlusI' tag='自动数据LTE（New）' />
                                                <button id='AutoInsertExcelDataThreadNew' label='自动数据LTE(多线程)(New)' imageMso='ConnectionPoints' onAction='OnButtonClick' screentip='根据模板数据覆写N个类似数据到表格：EPPlusI，多线程更快速' tag='自动数据LTE(多线程)（New）' />
                                                <button id='AutoInsertExcelDataModelCreat' label='特殊写入' imageMso='ConnectedToolSyncMenu' onAction='OnButtonClick' screentip='修正已存在的表格值（例如：LTE皮肤xxx【模版】），无法自增或者批量替换：EPPlusI' tag='特殊写入' />
                                        </menu>
                                        <button id='AutoInsertExcelDialog' size='large' label='自动数据&#13;(对话类)' image='nd_自动数据对话类' onAction='OnButtonClick' screentip='根据模板数据覆写对话数据表格：EPPlusI' tag='自动数据(对话类)' />
                                        <button id='AutoInsertIconFix' size='large' label='图片Fix' image='nd_图片Fix' onAction='OnButtonClick' screentip='针对Icon.xlsx表格图片资源修正数据的同步，复制【Ctr+V】点击按钮执行' tag='图片Fix' />
                                </group>
                                <!-- ══ Excel搜索 ══ -->
                                <group id="Group8" label="Excel搜索">
                                        <labelControl id='SearchLab' label='搜索编号/关键字' />
                                        <editBox id="ExcelSearchBoxEdit" label='输入查找值' onChange="ExcelOnEditBoxTextChanged" sizeString="………………………………………………………" screentip='前缀加*表示模糊搜索&#13;常规模版支持多ID：逗号/换行分隔，如 763601,763651' getText='GetEditBoxDefaultText'/>
                                        <menu id='ExcelSearchBoxMenu' label='全局搜索' image='nd_全局搜索菜单' size='large'>
                                                <button id="ExcelSearchBoxButton1" label="全局搜索" screentip='全列，按照A-Z的顺序遍历文件' onAction='OnButtonClick' imageMso="FindDialogExcel" tag='全局搜索' />
                                                <button id="ExcelSearchBoxButton3" label="全局搜索(多线程)" screentip='全列，按照A-Z的顺序遍历文件' onAction='OnButtonClick' imageMso="FindDialog" tag='全局搜索(多线程)' />
                                                <button id="ExcelSearchBoxButton2" label="编号搜索(多线程)" screentip='二列，按照A-Z的顺序遍历文件' onAction='OnButtonClick' imageMso="FindDialogExcel" tag='编号搜索(多线程)' />
                                                <button id="ExcelSearchBoxButton4" label="合并数据-关键词" screentip='合并Excel(Alice-Cove)当前关键词' onAction='OnButtonClick' imageMso="AdpNewTable" tag='合并数据-关键词' />
                                                <button id="ExcelSearchBoxButton7" label="搜索Sheet名" screentip='遍历public下所有xlsx，找出包含该Sheet名的工作簿' onAction='OnButtonClick' imageMso="SheetInsert" tag='搜索Sheet名' />
                                        </menu>
                                        <menu id='AutoInsertExcelDataMenu2' label='创建数据' image='nd_创建数据菜单' size='large'>
                                                <button id="ModelDataCreat" label="常规模版" screentip='全局搜索关键词，输出表格数据，常规模版数据，例如：各类LTE、主岛活动常规【模版】&#13;支持多ID：输入框用逗号/换行分隔，如 763601,763651，每张表取最小行和最大行' onAction='OnButtonClick' imageMso="TableInsert" tag='常规模版' />
                                                <button id="ModelDataCreat2" label="特殊模版" screentip='指定表格搜索关键词，输出表格数据，特殊模版数据，例如：LTE皮肤【模版】' onAction='OnButtonClick' imageMso="SheetInsert" tag='特殊模版' />
                                        </menu>
                                        <menu id='CurrentSheetMenu' label='当前表操作' image='nd_当前表操作菜单' size='large'>
                                                <button id="BatchReplaceInSelectionBtn" label="批量替换" screentip='对选中单元格执行多组批量替换（Ctrl+Alt+H）' onAction='OnButtonClick' imageMso="ReplaceDialog" tag='批量替换' />
                                                <button id="ExcelSearchBoxButton5" label="替换文本" screentip='搜索当前激活表格中包含特别的字符串并替换' onAction='OnButtonClick' imageMso="ReplaceDialog" tag='替换文本(当前表格)' />
                                                <button id="ExcelSearchBoxButton6" label="搜索文本" screentip='搜索当前激活表格中包含特别的字符串' onAction='OnButtonClick' imageMso="FindDialogExcel" tag='替换文本(当前表格)' />
                                                <button id="ExcelSearchBoxButton8" label="搜索公式名" screentip='搜索当前Excel中使用的公式' onAction='OnButtonClick' imageMso="FormulaEvaluate" tag='搜索公式名' />
                                        </menu>
                                        <button id="ExcelDataToDb" size='large' label="数据DB化" screentip='备份Public下配置Excel文件数据库化，方便更高效的查询' onAction='OnButtonClick' image='nd_Excel数据DB化' tag='Excel数据DB化' />
                                </group>
                                <!-- ══ 运营工具 ══ -->
                                <group id="Group9" label="运营工具">
                                        <menu id='ActivityGenMenu' label='生成活动&#13;' image='nd_生成活动菜单' size='large'>
                                                <button id="ActivityServerDataButton1" label="生成活动(活动名)" screentip='根据运营排期自动生成活动配置' onAction='OnButtonClick' imageMso="TableInsert" tag='生成活动(活动名)' />
                                                <button id="ActivityServerDataButton2" label="生成活动(活动ID)" screentip='根据运营排期自动生成活动配置' onAction='OnButtonClick' imageMso="AdpNewTable" tag='生成活动(活动ID)' />
                                                <button id="ActivityServerDataButton3" label="更新活动" screentip='根据运营排期自动更新活动配置' onAction='OnButtonClick' imageMso="DataRefreshAll" tag='更新活动' />
                                        </menu>
                                        <button id="CompareExcelButton" size='large' label="对比Excel" screentip='对比不同版本同路径下的非#Excel文件，输出至【文档\#表格比对结果.xlsx】' onAction='OnButtonClick' image='nd_对比Excel' tag='对比Excel' />
                                        <button id="MapExcelButton" size='large' label="溯源改动" screentip='根据对比结果和【文档\表格关系.json】溯源每条改动最终影响的表格，一般为ActivityClientData.xlsx，输出至【文档\#溯源结果.xlsx】' onAction='OnButtonClick' image='nd_溯源改动' tag='溯源改动' />
                                        <button id="CheckFileFormat" size='large' label="检查数据&#13;格式" screentip='手动检查数据格式，取消隐藏，过滤符配置在\Document\NumDesToolsConfig.json' onAction='OnButtonClick' image='nd_检查数据格式' tag='检查数据格式' />
                                        <button id="ActivityRulesUpdateButton" size='large' label="更新活动&#13;规则" screentip='扫描 EnumCmds/ActivityManager/LogicBase 自动补全 ActivityTableRules.json 的 typeTableMap（只增不改）' onAction='OnButtonClick' image='nd_更新活动规则' tag='更新活动规则' />
                                </group>
                                <!-- ══ 冲突与活动 ══ -->
                                <group id='GroupConflictMain' label='冲突与活动'>
                                        <menu id='ExcelConflictMenuMain' label='xlsx冲突&#13;解决' image='nd_xlsx冲突菜单' size='large' screentip='解决 xlsx 文件的 Git 合并冲突，或手动对比两个 xlsx 文件'>
                                                <button id="ExcelConflictGit" label="解决Git冲突" imageMso="ResolveConflict" onAction='OnButtonClick' screentip='自动检测 Git 冲突的 xlsx，逐格选择保留哪一方' tag='解决Git冲突' />
                                                <button id="ExcelConflictManual" label="手动两文件对比" imageMso="ReviewCompareTwoVersions" onAction='OnButtonClick' screentip='选择两个 xlsx 文件，逐格对比并选择合并结果' tag='手动两文件对比' />
                                                <button id="ExcelConflictHistory" label="查看历史版本对比" imageMso="SourceControlShowHistory" onAction='OnButtonClick' screentip='浏览某个 xlsx 的 Git 提交历史，选历史版本与工作区或另一历史版本对比' tag='查看历史版本对比' />
                                                <menuSeparator id="ConflictSep1"/>
                                                <button id="ExcelBranchMerge" label="分支合并/Cherry-pick" imageMso="SourceControlMerge" onAction='OnButtonClick' screentip='将另一分支合并到当前分支，或摘取指定 commit，冲突 xlsx 用可视化窗口解决' tag='分支合并CherryPick' />
                                        </menu>
                                        <menu id='ActivityValidateMenuMain' label='验证活动&#13;' image='nd_验证活动菜单' size='large'>
                                                <button id="ActivityTestAll" label="验证活动(全量)" screentip='验证所有活动配置表的跨表引用和字段规则' onAction='OnButtonClick' imageMso="DataValidation" tag='验证活动(全量)' />
                                                <button id="ActivityTestById" label="验证活动(指定ID)" screentip='输入活动ID验证配置链完整性' onAction='OnButtonClick' imageMso="ErrorChecking" tag='验证活动(指定ID)' />
                                                <button id="ActivityTestGitChanged" label="验证活动(Git改动)" screentip='只验证当前Git工作区有改动的活动表' onAction='OnButtonClick' imageMso="FieldsUpdate" tag='验证活动(Git改动)' />
                                        </menu>
                                </group>
                                <!-- ══ 文件信息 ══ -->
                                <group id='FileInfo' label='文件信息'>
                                        <button id='CopyFileName' size='large' label='文件名称' image='nd_文件名称' onAction='OnButtonClick' tag='文件名称' />
                                        <button id='CopyFilePath' size='large' label='文件路径' image='nd_文件路径' onAction='OnButtonClick' tag='文件路径' />
                                        <labelControl id="BasePathLab" label=" 源表/目标" />
                                        <editBox id="BasePathEdit" getText="GetFileInfo" onChange="FileInfoChanged" sizeString="........................................................................." image="folder-android" screentip='输入自己本地目录，自动保存' />
                                        <editBox id="TargetPathEdit" getText="GetFileInfo" onChange="FileInfoChanged" sizeString="........................................................................." image="folder-aws" screentip='输入自己本地目录，自动保存' />
                                </group>
                                <!-- ══ 帮助 ══ -->
                                <group id='GroupHelp' label='帮助'>
                                        <button id='HelpButton' size='large' label='功能说明书' imageMso='Help' onAction='OnButtonClick' screentip='打开 NumDesTools 图文帮助，查看各功能说明与使用步骤' tag='帮助' />
                                </group>
                        </tab>
                        <tab id='SecondTab' label='NumDesToolsPlus' insertBeforeMso='TabHome'>
                                <group id='GroupMoved' label='常用工具'>
                                        <button id='Button4' size='large' label='标准格式' image='nd_标准格式' onAction='OnButtonClick' screentip='将选中单元格修改为标准格式' tag='标准格式' />
                                        <button id='Button5' size='large' getLabel='GetLableText' image='nd_放大镜' onAction='OnButtonClick' screentip='放大镜开关，对当前选中单元格进行放大显示' tag='放大镜开关' />
                                        <button id='FocusLightButton' size='large' getLabel='GetLableText' image='nd_聚光灯菜单' onAction='OnButtonClick' screentip='聚光灯开关：半透明行列色条覆盖显示，不修改单元格格式' tag='聚光灯-Overlay' />
                                        <button id='CellHistoryTipButton' size='large' getLabel='GetLableText' image='nd_单元格历史' onAction='OnButtonClick' screentip='选择任务单元格以确定这个单元格的值最近是谁改的，并甩锅给TA！' tag='单元格历史' />
                                        <button id='AutoMergeExcel' size='large' label='合并Excel&#13;(Alice-Cove)' image='nd_合并Excel' onAction='OnButtonClick' screentip='合并Alice和Cove的Excel配置数据' tag='合并Excel(Alice-Cove)' />
                                        <button id='AutoSeachExcel' size='large' label='查验模版&#13;写入数据' image='nd_查验模版写入数据' onAction='OnButtonClick' screentip='查验模版写入数据是否正确' tag='查验模版写入数据' />
                                        <button id='AutoInsertNumChanges' size='large' label='活动奖励&#13;写入' image='nd_活动奖励写入' onAction='OnButtonClick' screentip='活动奖励数据写入' tag='活动奖励写入' />
                                        <button id="XlsxSyncSettings" size='large' label="跨表同步&#13;设置" screentip='配置根目录 A/B 及 a 侧文件名后缀，Sheet 和同步列全自动比对，不用手配' onAction='OnButtonClick' image='nd_跨表同步设置' tag='跨表同步设置' />
                                        <button id="XlsxSyncForward" size='large' label="同步&#13;a→b" screentip='当前需在根目录 A 下打开的文件，自动找到 B 侧对应文件，比对同名 Sheet 的表头交集列（约定 id 列为 Key）同步过去' onAction='OnButtonClick' image='nd_跨表同步正向' tag='同步a→b' />
                                        <button id="XlsxSyncReverse" size='large' label="同步&#13;b→a" screentip='当前需在根目录 B 下打开的文件，反向同步回 A 侧对应文件，规则同「同步 a→b」' onAction='OnButtonClick' image='nd_跨表同步反向' tag='同步b→a' />
                                </group>
                                <group id='Group10' label='玩法计算'>
                                        <button id='Button15' size='large' label='Alice大富翁' image='nd_Alice大富翁' screentip='大富翁方案整理' onAction='OnButtonClick' tag='Alice大富翁' />
                                        <button id='Button16' size='large' label='TM目标元素' image='nd_TM目标元素' screentip='Tm目标元素生成' onAction='OnButtonClick' tag='TM目标元素' />
                                        <button id='Button17' size='large' label='TM非目标元素' image='nd_TM非目标元素' screentip='Tm非目标元素生成' onAction='OnButtonClick' tag='TM目标元素' />
                                        <button id='Button_MagicBottle' size='large' label='移动魔瓶' image='nd_移动魔瓶' screentip='移动魔瓶消耗模拟计算' onAction='OnButtonClick' tag='移动魔瓶' />
                                        <button id='Button_LoopRun' size='large' label='移动转盘' image='nd_移动转盘' screentip='移动转盘随机方案机选' onAction='OnButtonClick' tag='移动转盘' />
                                        <button id='Button_CardRatioSim' size='large' label='万能卡概率' image='nd_万能卡概率' screentip='相册万能卡概率模拟' onAction='OnButtonClick' tag='万能卡概率' />
                                        <button id='CheckColFromExcelMulti' size='large' label='删除冗余列' image='nd_删除冗余列' onAction='OnButtonClick' screentip='删除表格冗余列，以及Chart1类的非法配置表，打开的表格不能格式错误' tag='批量整理表格格式' />
                                </group>
                                <group id='NormalFun' label='杂项'>
                                        <button id='ShowDnaLog' size='large' getLabel='GetLableText' image='nd_插件日志' onAction='OnButtonClick' screentip='展示插件Log' tag='插件日志开关' />
                                        <button id='GlobalVariableDefault' size='large' label='默认配置' image='nd_默认配置' onAction='OnButtonClick' screentip='恢复插件配置为默认' tag='默认配置' />
                                </group>
                                <group id='GroupAI' label='AI聚合'>
                                        <button id='ShowAI' size='large' getLabel='GetLableText' image='nd_AI对话' onAction='OnButtonClick' tag='AI对话开关' />
                                        <button id='ShowAIAgent' size='large' getLabel='GetLableText' image='nd_AI对话' onAction='OnButtonClick' tag='AI Agent开关' />
                                </group>
                                <group id='Group9999' label='测试功能区'>
                                        <button id='Button99991' size='large' label='不要点击红色按钮' image='sofa' onAction='OnButtonClick' tag='不要点击红色按钮' />
                                        <button id='Button99992' size='large' label='测试' image='sofa' onAction='OnButtonClick' tag='测试' />
                                        <checkBox id='checkbox99991' label='是否后台' />
                                </group>
                        </tab>
                </tabs>
        </ribbon>
</customUI>
